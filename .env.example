# ==================== Database ====================

# MongoDB Atlas connection string
# Get connection string at: https://cloud.mongodb.com/
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/vertax?retryWrites=true&w=majority"

# ==================== Auth ====================
AUTH_SECRET="generate-a-random-secret-here"
# In local development, leave AUTH_URL / NEXTAUTH_URL unset so Auth.js follows
# the current host and port automatically. Set a fixed URL only in deployed envs.
# NEXTAUTH_URL="https://app.vertax.top"

# Demo mode (set to "false" for production)
NEXT_PUBLIC_DEMO_MODE="true"

# OpenAI (for AI content generation)
OPENAI_API_KEY=""

# Facebook OAuth & Graph API
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""

# Twitter/X OAuth 2.0
TWITTER_CLIENT_ID=""
TWITTER_CLIENT_SECRET=""

# App URL (used for OAuth redirect URIs)
# In local development, leave this unset so OAuth routes use the current request
# origin. Set a fixed public origin only in deployed environments.
# NEXT_PUBLIC_APP_URL="https://app.vertax.top"

# Optional: local tenant workspace debugging on localhost.
# Keep real vertax.top subdomains pointed at Vercel; do not map them to 127.0.0.1 in hosts.
# NEXT_PUBLIC_VIEW_MODE="customer"
# NEXT_PUBLIC_TENANT_SLUG="tdpaint"

# Cron secret (for scheduled publishing endpoint)
CRON_SECRET="generate-a-random-secret-here"

# ==================== Radar Discovery APIs ====================

# Google Maps Places API (for company discovery via MAPS channel)
# Get key at: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=""

# Brave Search API (for AI-powered company discovery)
# Get key at: https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=""

# SerpAPI (alternative search backend for AI search)
SERPAPI_KEY=""

# Exa AI Search (for radar candidate enrichment)
# Get key at: https://exa.ai/
EXA_API_KEY=""

# Firecrawl (for web scraping / page extraction)
# Get key at: https://www.firecrawl.dev/
FIRECRAWL_API_KEY=""

# Bing Search API (alternative search backend)
BING_SEARCH_KEY=""

# ==================== Email Service (Resend) ====================

# Resend API Key for email sending (platform-level)
# Get key at: https://resend.com/api-keys
# IMPORTANT: Configure real API key in production!
RESEND_API_KEY="re_placeholder_configure_in_production"

# Default sender email address (must use verified domain)
RESEND_FROM_EMAIL="VertaX <noreply@vertax.top>"

# ==================== Document Processing APIs ====================

# AssemblyAI (for audio/video transcription)
# Get key at: https://www.assemblyai.com/
# Free tier: 5 hours/month
ASSEMBLYAI_API_KEY=""

# Azure Document Intelligence (for large document OCR)
# Get credentials at: https://portal.azure.com/
# Create resource: Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=""
AZURE_DOCUMENT_INTELLIGENCE_KEY=""

# ==================== Document Processing Microservice ====================

# Processor Service URL (deployed on Railway or other platform)
# Example: https://vertax-processor.railway.app
PROCESSOR_SERVICE_URL=""

# Processor Service API Key (shared secret for authentication)
# Generate a secure random key: openssl rand -base64 32
PROCESSOR_API_KEY=""

# ==================== AI Providers ====================
