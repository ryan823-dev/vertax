// ==================== WEB CRAWL QUEUE ====================

model CrawlQueue {
  id       String  @id @default(cuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String // йҚҷжҲЈжҚЈйҗўг„Ұеҹӣ ID
  batchId  String  @unique // йҗўг„Өз°¬йҚ“е¶ҮоҒ¬жқһоҶҝоҮ—
  rootUrl  String // йҸҚ?URL
  folderId String? // йҚҷоҲһвӮ¬еӨҢж®‘йҸӮеӣҰж¬ўжҫ¶?ID

  // жқ©ж¶ҳе®із’әзҶ»йҮң
  totalPages     Int
  processedPages Int    @default(0)
  status         String @default("pending") // pending | processing | completed | failed

  // URL й—ғзҶ·еһӘ (JSON йҸҒжү®зІҚ)
  urls Json // [{ url, status, priority, assetId?, error?, processedAt? }]

  // йҚҸеҶ©жҡҹйҺ№?
  metadata Json? // { discoveryMethod, requestedAt, maxPagesRequested, lastProcessedAt, lastStats, completedAt, lastError }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([batchId])
  @@index([tenantId, status])
  @@map("crawl_queue")
}

// ==================== ASSET PROCESSING QUEUE ====================
// йҚҡеәЎеҪҙжҫ¶еӢӯжӮҠжҫ¶С„жһғжө иҲөжһғйҸҲо„ҒеҪҒйҚҷж §жӢ°йҚ’е——жҪЎ

model AssetProcessQueue {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String // йҚҷжҲЈжҚЈйҗўг„Ұеҹӣ ID
  batchId  String @unique // йҗўг„Өз°¬йҚ“е¶ҮоҒ¬жқһоҶҝоҮ—

  // йҚҸе® д»Ҳз’§еӢӘйӘҮ
  assetId    String
  storageKey String
  mimeType   String

  // жқ©ж¶ҳе®із’әзҶ»йҮң
  status      String  @default("pending") // pending | extracting | chunking | completed | failed
  progress    Int     @default(0) // 0-100 йҗ§жғ§еһҺе§Ј?
  currentStep String? // "extracting_text" | "splitting_chunks" | "creating_records"

  // й–ҝж¬’оҮӨж·Үв„ғдј…
  errorMessage String?

  // йҚҸеҶ©жҡҹйҺ№?
  metadata Json? // { fileName, fileSize, chunkCount?, textLength?, startedAt?, completedAt? }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([batchId])
  @@index([assetId])
  @@index([tenantId, status])
  @@map("asset_process_queue")
}

// йҚҹе——е§ҹйҚңг„ЁоҮ—йҗЈж¬’в–Ҳй”ӣе ҹжҪөй‘·оҒҶж«ҘиӨ°жӣўгҖү"й‘ҫеі°еҪҮжөЈи·Ёж•Өз’§еӢ¬зүё"йҚҸгғҘеҪӣй”ӣ?
model Inquiry {
  id        String   @id @default(cuid())
  name      String
  company   String
  email     String
  phone     String?
  message   String?
  status    String   @default("new") // new | read | handled
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("inquiries")
}