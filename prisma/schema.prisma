generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== TENANT & AUTH ====================
// ==================== TENANT & AUTH ====================

model Tenant {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  domain      String?
  plan        String    @default("free")
  status      String    @default("active")
  settings    Json      @default("{}")
  emailConfig Json? // й–ӯоҶ»ж¬ўй–°е¶Үз–Ҷй”ӣж°¬й’©йҚҷзҷ’ey/й‘·оҒ„з•ҫж¶”еЎҠeyйҠҶдҪёеҪӮжө и·әз…ҷйҚҡе¶Үз“‘
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  users              User[]
  products           Product[]
  seoContents        SeoContent[]
  seoAudits          SeoAudit[]
  socialPosts        SocialPost[]
  socialAccounts     SocialAccount[]
  leads              Lead[]
  campaigns          Campaign[]
  categories         ContentCategory[]
  websiteConfigs     WebsiteConfig[]
  activities         Activity[]
  notifications      Notification[]
  assetFolders       AssetFolder[]
  assets             Asset[]
  apiKeys            ApiKey[]
  companyProfile     CompanyProfile?
  assetChunks        AssetChunk[]
  evidences          Evidence[]
  brandGuidelines    BrandGuideline[]
  icpSegments        ICPSegment[]
  personas           Persona[]
  messagingMatrices  MessagingMatrix[]
  // Phase 3
  artifactVersions   ArtifactVersion[]
  contentBriefs      ContentBrief[]
  chatConversations  ChatConversation[]
  prospectCompanies  ProspectCompany[]
  // Web crawl queue
  crawlQueues        CrawlQueue[]
  // Asset processing queue
  assetProcessQueues AssetProcessQueue[]
}

model WebsiteConfig {
  id              String  @id @default(cuid())
  tenantId        String
  tenant          Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  siteName        String? // йҗ©оҶҪзҲЈз»”ж¬ҸжӮ•з»үеё®зҙҷжҫ¶ж°ұзҸҜйҚ–е“„еһҺй”ӣ?
  url             String?
  apiKey          String?
  publishEndpoint String?
  seoDefaults     Json    @default("{}")

  // === Publishing Pipeline йҺөв•ҒзқҚ ===
  siteType             String  @default("supabase") // supabase | nextjs | wordpress | rest
  supabaseUrl          String? // [supabase] e.g. "https://xxx.supabase.co"
  functionName         String? // [supabase] e.g. "receive-content-push"
  webhookUrl           String? // [nextjs | rest] зҖ№гҲЎеҹӣз»”ж¬җеёҙйҸҖ?endpoint
  wpUrl                String? // [wordpress] WP з»”ж¬‘еҒЈйҸҚ?URL
  wpUsername           String? // [wordpress] WP йҗўг„ҰеҹӣйҚҡ?
  wpPassword           String? // [wordpress] Application Password
  pushSecret           String? // йҚҸеҸҳйҹ©зҖөе—ӣжҢңй”ӣеңҡMACз»ӣжғ§жӮ• / Bearer tokenй”ӣ?
  customHeaders        Json? // й‘·оҒ„з•ҫж¶”еӨҺоҮ¬е§№еӮҡгҒ”й”ӣеқ®est/nextjs йҗўоҹ’зҙҡ
  fieldMapping         Json    @default("{}") // Vertax йҲ«?йҗ©оҶҪзҲЈз»”ж¬Ҹз“§еЁҲеһ«ж§§зҒҸ?
  approvalTimeoutHours Int     @default(24)
  isActive             Boolean @default(true)

  pushRecords PushRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// ==================== CONTENT PUSH PIPELINE ====================

enum PushStatus {
  PENDING // е®ёеҸүеё№й–«дҫҠзҙқз»ӣеӨҠз·ҹзҖ№гҲЎеҹӣз»”ж¬‘еҒЈзҖ№в„ғзүі
  CONFIRMED // зҖ№гҲЎеҹӣз»”ж¬‘еҒЈе®ёиҢ¬вҖҳз’ҒгӮ…еҪӮз”Ҝ?
  TIMEOUT // з“’е‘®жӨӮйҸҲоҒҶвҖҳз’Ғ?
  FAILED // йҺәг„©вӮ¬дҪёгҒ‘з’җ?
  ESCALATED // е®ёжҸ’еҙҢз»ҫСғеҹҢжқ©ж„ҜжғҖжҫ¶еӢӯжӮҠ
}

model PushRecord {
  id       String @id @default(cuid())
  tenantId String

  // йҚҸе® д»ҲйҚҗе‘ӯоҶҗ
  contentId String // SeoContent.id
  content   SeoContent @relation(fields: [contentId], references: [id], onDelete: Cascade)

  // йҗ©оҶҪзҲЈз»”ж¬‘еҒЈ
  websiteConfigId String
  websiteConfig   WebsiteConfig @relation(fields: [websiteConfigId], references: [id], onDelete: Cascade)

  // йҺәг„©вӮ¬дҪәе§ёйҺ¬?
  status     PushStatus @default(PENDING)
  remoteId   String? // йҗ©оҶҪзҲЈз»”ж¬‘еҒЈжқ©ж–ҝжҙ–йҗЁеӢ®оҶҮиӨ°?ID
  remoteSlug String? // йҗ©оҶҪзҲЈз»”ж¬‘еҒЈйҗЁ?slug
  targetUrl  String? // йҗ©оҶҪзҲЈз»”ж¬‘еҒЈж¶“е©„ж®‘зҖ№еұҫжҡЈ URL

  // зҖӣжҘҒоҶҢи№ҮоӮӨеҸҺй”ӣе ҹеё№й–«дҪ№жӨӮйҗЁеӢ¬ж§§зҒҸеӢӯзІЁйҸӢж»җзҙҡ
  pushPayload     Json? // зҖ№зӮәжӘҜйҚҷжҲҰвӮ¬дҪәж®‘ payload и№ҮоӮӨеҸҺ
  contentVersion  Int? // йҺәг„©вӮ¬дҪ№жӨӮзҖөз‘°з°ІйҗЁ?SeoContent.version
  contentSnapshot Json? // { title, slug, excerpt, keywords } и№ҮоӮӨеҸҺ

  // йҸғе •жЈҝжқ©еҖҹйҮң
  pushedAt    DateTime  @default(now())
  timeoutAt   DateTime // pushedAt + approvalTimeoutHours
  confirmedAt DateTime?
  escalatedAt DateTime?

  // й–ҝж¬’оҮӨжҫ¶еӢӯжӮҠ
  retryCount Int     @default(0)
  lastError  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contentId, websiteConfigId]) // е§ЈеҝҺйҮңйҚҗе‘ӯоҶҗе§ЈеҝҺйҮңз»”ж¬‘еҒЈйҚҷоҒ…ж№Ғж¶“вӮ¬йҸүв„ғеё№й–«дҪҪоҶҮиӨ°?
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?
  tenantId      String?
  tenant        Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roleId        String
  role          Role      @relation(fields: [roleId], references: [id])
  locale        String    @default("zh-CN")
  timezone      String    @default("Asia/Shanghai")
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  accounts          Account[]
  sessions          Session[]
  seoContents       SeoContent[]
  seoAudits         SeoAudit[]
  socialPosts       SocialPost[]
  ownedLeads        Lead[]
  activities        Activity[]
  assets            Asset[]
  evidences         Evidence[]
  // Phase 3
  artifactVersions  ArtifactVersion[]
  contentBriefs     ContentBrief[]
  artifactComments  ArtifactComment[]
  tasksCreated      ArtifactTask[]     @relation("TaskCreator")
  tasksAssigned     ArtifactTask[]     @relation("TaskAssignee")
  chatConversations ChatConversation[]
}

model Role {
  id           String   @id @default(cuid())
  name         String   @unique
  displayName  String
  permissions  Json
  isSystemRole Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users User[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ApiKey {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  key         String    @unique
  permissions String[]  @default(["assets:write"])
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ==================== MODULE 1: PRODUCTS ====================

model Product {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sku             String?
  name            String
  slug            String
  description     String?
  detailedContent String?
  status          String    @default("draft")
  publishedAt     DateTime?
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  images     ProductImage[]
  specs      ProductSpec[]
  categories ProductCategory[]

  @@unique([tenantId, slug])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  altText   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model ProductSpec {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  key       String
  value     String
  unit      String?
  order     Int     @default(0)
}

model ProductCategory {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String

  @@unique([productId, name])
}

// ==================== MODULE 2: SEO & GEO CONTENT ====================

model SeoAudit {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  targetUrl     String
  status        String    @default("pending")
  progress      Int       @default(0)
  currentStep   String?
  scores        Json      @default("{}")
  findings      Json      @default("[]")
  aiSummary     String?
  crawlErrors   Json      @default("[]")
  pagesCrawled  Int       @default(0)
  crawlDuration Int?
  createdAt     DateTime  @default(now())
  completedAt   DateTime?
}

model ContentCategory {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  description String?
  icon        String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contents SeoContent[]

  @@unique([tenantId, slug])
}

model SeoContent {
  id              String          @id @default(cuid())
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId      String
  category        ContentCategory @relation(fields: [categoryId], references: [id])
  authorId        String
  author          User            @relation(fields: [authorId], references: [id])
  title           String
  slug            String
  excerpt         String?
  content         String
  metaTitle       String?
  metaDescription String?
  keywords        String[]
  featuredImage   String?
  status          String          @default("draft")
  publishedAt     DateTime?
  scheduledAt     DateTime?
  version         Int             @default(1) // йҚҗе‘ӯоҶҗйҗ—е ҹж№°йҚҷеҮӨзҙқе§Јеҝ”оӮјж·ҮжҝҶз“Ёй‘·оҒ„е§© +1
  aiMetadata      Json            @default("{}")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  // Phase 3 йҺөв•ҒзқҚ
  briefId          String?
  brief            ContentBrief?           @relation(fields: [briefId], references: [id], onDelete: SetNull)
  outline          Json? // { sections: [{ heading, keyPoints }] }
  evidenceRefs     String[] // еҜ®жӣ ж•ӨйҗЁ?Evidence id
  schemaJson       Json? // Schema.org зјҒж’ҙзҖҜйҚ–ж ЁжҡҹйҺ№?(FAQPage JSON-LD)
  geoVersion       String? // GEO-optimized short version (300-500 words, for AI citation)
  pushRecords      PushRecord[] // йҺәг„©вӮ¬дҪҪоҶҮиӨ°?
  contentLinks     RadarContentLink[] // й‘ҫеі°о…№й—Ҷз–ҜжҸӘйҚҗе‘ӯоҶҗй‘ұж–ҝе§©
  geoDistributions GeoDistributionRecord[] // GEO йҚ’е——еҪӮжқ©еҖҹйҮң

  @@unique([tenantId, slug])
}

// ==================== MODULE 3: SOCIAL MEDIA ====================

model SocialAccount {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  platform     String
  accountName  String
  accountId    String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  metadata     Json      @default("{}")
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([tenantId, platform, accountId])
}

model SocialPost {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  authorId     String
  author       User      @relation(fields: [authorId], references: [id])
  title        String?
  status       String    @default("draft")
  scheduledAt  DateTime?
  publishedAt  DateTime?
  autoEngage   Boolean   @default(false)
  engageConfig Json      @default("{}")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  versions PostVersion[]
}

model PostVersion {
  id              String     @id @default(cuid())
  postId          String
  post            SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  platform        String
  content         String
  media           String[]
  platformPostId  String?
  publishedAt     DateTime?
  error           String?
  publishAttempts Int        @default(0)
  metrics         Json       @default("{}")
}

// ==================== MODULE 4: AI LEAD GENERATION ====================

model Lead {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ownerId         String
  owner           User      @relation(fields: [ownerId], references: [id])
  companyName     String
  contactName     String?
  email           String?
  phone           String?
  website         String?
  country         String?
  city            String?
  industry        String?
  companySize     String?
  status          String    @default("new")
  priority        String    @default("medium")
  researchData    Json      @default("{}")
  notes           String?
  lastContactedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  campaigns CampaignLead[]
}

model Campaign {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  emailTemplate  String
  subject        String
  status         String    @default("draft")
  scheduledStart DateTime?
  scheduledEnd   DateTime?
  metrics        Json      @default("{}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  leads CampaignLead[]
}

model CampaignLead {
  id                  String    @id @default(cuid())
  campaignId          String
  campaign            Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  leadId              String
  lead                Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  status              String    @default("pending")
  sentAt              DateTime?
  openedAt            DateTime?
  repliedAt           DateTime?
  personalizedContent String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([campaignId, leadId])
}

// ==================== SYSTEM ====================

model Activity {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String
  entityType String
  entityId   String
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  // Phase 3 йҺөв•ҒзқҚ
  eventCategory String? // "knowledge"|"marketing"|"review"|"chat"|"system"
  severity      String? // "info"|"warn"|"error"
  context       Json? // { versionId, briefId, previousStatus, ... }
}

// ==================== MODULE 6: KNOWLEDGE ENGINE ====================

// ==================== ENUMS (Knowledge) ====================

enum EvidenceType {
  claim
  statistic
  testimonial
  case_study
  certification
}

enum GuidelineCategory {
  tone
  terminology
  visual
  messaging
}

// ==================== Phase 3: Artifact Versioning ====================

enum ArtifactStatus {
  draft
  in_review
  client_feedback
  revised
  approved
  published // UIй—…ж„ҜжЈҢй”ӣеұҪжӮ—зјҒо…һжғҺйҗў?
  archived
}

model CompanyProfile {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // жөјдҪ·з¬ҹйҚ©зғҳж№°ж·Үв„ғдј…й”ӣең“IйҺ»ж„®еҒ§й”ӣ?
  companyName  String?
  companyIntro String?

  // йҸҚзЁҝзёҫй‘іи—үе§ҸйҗўиҜІе„ҡ
  coreProducts    Json @default("[]") // йҸҚзЁҝзёҫжөңСғжҗ§/йҸҲе¶…е§ҹй‘іи—үе§Ҹ
  techAdvantages  Json @default("[]") // йҺ¶вӮ¬йҸҲоҲҷзҙӯйҚ”?
  scenarios       Json @default("[]") // й–«еӮңж•ӨйҚҰзғҳж«ҷ/зҗӣеұјз¬ҹ
  differentiators Json @default("[]") // е®ёоҶјзҙ“йҚ–ж §еҙ йҗҗ?

  // йҗ©оҶҪзҲЈзҖ№гҲЎеҹӣйҗўиҜІе„ҡ (ICP)
  targetIndustries Json @default("[]") // йҗ©оҶҪзҲЈзҗӣеұјз¬ҹ
  targetRegions    Json @default("[]") // йҗ©оҶҪзҲЈйҚҰжқҝе°Ҝ
  buyerPersonas    Json @default("[]") // ж¶”жқҝоҶҚз‘ҷжҺ•еЈҠ
  painPoints       Json @default("[]") // зҖ№гҲЎеҹӣйҗҘж¶ҡеҒЈ
  buyingTriggers   Json @default("[]") // з’җо…қжӢұз‘ҷп№ҖеҪӮйҚҘзҠөзӨҢ

  // AI йҚ’е—ҳзҖҪйҚҸеҶ©жҡҹйҺ№?
  lastAnalyzedAt DateTime?
  analysisSource Json      @default("[]") // йҚ’е—ҳзҖҪжөЈи·Ёж•ӨйҗЁеӢӯзӨҢйҸүжҖҡDйҚ’жҘ„гҖғ
  aiModel        String? // жөЈи·Ёж•ӨйҗЁеҮҷIеҰҜвҖізҖ·
  rawAnalysis    String? // AIйҚҳзҶ·оқҗйҚ’е—ҳзҖҪзјҒж’ҙзҒү

  // Phase 2 йҺөв•ҒзқҚ
  sectionEdits Json @default("{}") // { sectionKey: { content, editedAt, editedBy } }
  evidenceRefs Json @default("{}") // { sectionKey: string[] }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== MODULE 5: ASSET HUB ====================

model AssetFolder {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  parentId    String?
  parent      AssetFolder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children    AssetFolder[] @relation("FolderTree")
  color       String?
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  assets Asset[]

  @@unique([tenantId, name, parentId])
}

model Asset {
  id           String       @id @default(cuid())
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User         @relation(fields: [uploadedById], references: [id])
  folderId     String?
  folder       AssetFolder? @relation(fields: [folderId], references: [id])

  // йҸӮеӣҰж¬ўж·Үв„ғдј…
  originalName String
  storageKey   String
  mimeType     String
  fileSize     BigInt
  extension    String

  // йҚ’е—ҷиў«
  fileCategory String // video | image | document | audio | other
  purpose      String[] // knowledge | marketing | reference
  tags         String[]

  // йҚҗе‘ӯоҶҗ
  title       String
  description String?
  metadata    Json    @default("{}")

  // йҗҳиҲөвӮ¬?
  status    String    @default("uploading") // uploading | active | archived | deleted
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  chunks AssetChunk[]
}

// ==================== ASSET CHUNKS (йҸӮеӣЁж№°йҚ’е——жҪЎ) ====================

model AssetChunk {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assetId  String
  asset    Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  content    String
  chunkIndex Int
  pageNumber Int?
  charStart  Int?
  charEnd    Int?
  tokenCount Int?

  createdAt DateTime @default(now())

  evidences Evidence[]
}

