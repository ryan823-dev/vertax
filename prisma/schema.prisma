  // 閫氱敤瀛楁
  displayName String
  description String?

  // 鍏徃瀛楁锛坈andidateType=COMPANY锛?
  website     String?
  phone       String?
  email       String?
  address     String?
  country     String?
  city        String?
  industry    String?
  companySize String?

  // 鏈轰細瀛楁锛坈andidateType=OPPORTUNITY锛屽嵆鎷涙爣锛?
  deadline       DateTime?
