generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================== TENANT & AUTH ====================

model Tenant {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  domain    String?
  plan      String    @default("free")
  status    String    @default("active")
  settings  Json      @default("{}")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users          User[]
  products       Product[]
  seoContents    SeoContent[]
  seoAudits      SeoAudit[]
  socialPosts    SocialPost[]
  socialAccounts SocialAccount[]
  leads          Lead[]
  campaigns      Campaign[]
  categories     ContentCategory[]
  websiteConfig  WebsiteConfig?
  activities     Activity[]
  assetFolders      AssetFolder[]
  assets            Asset[]
  apiKeys           ApiKey[]
  companyProfile    CompanyProfile?
  assetChunks       AssetChunk[]
  evidences         Evidence[]
  brandGuidelines   BrandGuideline[]
  icpSegments       ICPSegment[]
  personas          Persona[]
  messagingMatrices MessagingMatrix[]
  // Phase 3
  artifactVersions   ArtifactVersion[]
  contentBriefs      ContentBrief[]
  chatConversations  ChatConversation[]
}

model WebsiteConfig {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  url             String?
  apiKey          String?
  publishEndpoint String?
  seoDefaults     Json     @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roleId        String
  role          Role      @relation(fields: [roleId], references: [id])
  locale        String    @default("zh-CN")
  timezone      String    @default("Asia/Shanghai")
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  accounts    Account[]
  sessions    Session[]
  seoContents SeoContent[]
  seoAudits   SeoAudit[]
  socialPosts SocialPost[]
  ownedLeads  Lead[]
  activities  Activity[]
  assets      Asset[]
  evidences   Evidence[]
  // Phase 3
  artifactVersions  ArtifactVersion[]
  contentBriefs     ContentBrief[]
  artifactComments  ArtifactComment[]
  tasksCreated      ArtifactTask[]     @relation("TaskCreator")
  tasksAssigned     ArtifactTask[]     @relation("TaskAssignee")
  chatConversations ChatConversation[]

  @@index([tenantId])
  @@index([email])
}

model Role {
  id           String   @id @default(cuid())
  name         String   @unique
  displayName  String
  permissions  Json
  isSystemRole Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users User[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ApiKey {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  key         String    @unique
  permissions String[]  @default(["assets:write"])
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
  @@index([key])
}

// ==================== MODULE 1: PRODUCTS ====================

model Product {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sku             String?
  name            String
  slug            String
  description     String?   @db.Text
  detailedContent String?   @db.Text
  status          String    @default("draft")
  publishedAt     DateTime?
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  images     ProductImage[]
  specs      ProductSpec[]
  categories ProductCategory[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([status])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  altText   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([productId])
}

model ProductSpec {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  key       String
  value     String  @db.Text
  unit      String?
  order     Int     @default(0)

  @@index([productId])
}

model ProductCategory {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String

  @@unique([productId, name])
  @@index([productId])
}

// ==================== MODULE 2: SEO & GEO CONTENT ====================

model SeoAudit {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  targetUrl     String
  status        String    @default("pending")
  progress      Int       @default(0)
  currentStep   String?
  scores        Json      @default("{}")
  findings      Json      @default("[]")
  aiSummary     String?   @db.Text
  crawlErrors   Json      @default("[]")
  pagesCrawled  Int       @default(0)
  crawlDuration Int?
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  @@index([tenantId])
  @@index([userId])
  @@index([status])
}

model ContentCategory {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  description String?
  icon        String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contents SeoContent[]

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model SeoContent {
  id              String          @id @default(cuid())
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId      String
  category        ContentCategory @relation(fields: [categoryId], references: [id])
  authorId        String
  author          User            @relation(fields: [authorId], references: [id])
  title           String
  slug            String
  excerpt         String?         @db.Text
  content         String          @db.Text
  metaTitle       String?
  metaDescription String?
  keywords        String[]
  featuredImage   String?
  status          String          @default("draft")
  publishedAt     DateTime?
  scheduledAt     DateTime?
  aiMetadata      Json            @default("{}")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  // Phase 3 扩展
  briefId      String?
  brief        ContentBrief?  @relation(fields: [briefId], references: [id], onDelete: SetNull)
  outline      Json?          // { sections: [{ heading, keyPoints }] }
  evidenceRefs String[]       // 引用的 Evidence id
  schemaJson   Json?          // Schema.org 结构化数据

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([categoryId])
  @@index([authorId])
  @@index([status])
  @@index([briefId])
}

// ==================== MODULE 3: SOCIAL MEDIA ====================

model SocialAccount {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  platform     String
  accountName  String
  accountId    String
  accessToken  String?   @db.Text
  refreshToken String?   @db.Text
  expiresAt    DateTime?
  metadata     Json      @default("{}")
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([tenantId, platform, accountId])
  @@index([tenantId])
}

model SocialPost {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  authorId     String
  author       User      @relation(fields: [authorId], references: [id])
  title        String?
  status       String    @default("draft")
  scheduledAt  DateTime?
  publishedAt  DateTime?
  autoEngage   Boolean   @default(false)
  engageConfig Json      @default("{}")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  versions PostVersion[]

  @@index([tenantId])
  @@index([authorId])
  @@index([status])
  @@index([scheduledAt])
}

model PostVersion {
  id              String     @id @default(cuid())
  postId          String
  post            SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  platform        String
  content         String     @db.Text
  media           String[]
  platformPostId  String?
  publishedAt     DateTime?
  error           String?
  publishAttempts Int        @default(0)
  metrics         Json       @default("{}")

  @@index([postId])
}

// ==================== MODULE 4: AI LEAD GENERATION ====================

model Lead {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ownerId         String
  owner           User      @relation(fields: [ownerId], references: [id])
  companyName     String
  contactName     String?
  email           String?
  phone           String?
  website         String?
  country         String?
  city            String?
  industry        String?
  companySize     String?
  status          String    @default("new")
  priority        String    @default("medium")
  researchData    Json      @default("{}")
  notes           String?   @db.Text
  lastContactedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  campaigns CampaignLead[]

  @@index([tenantId])
  @@index([ownerId])
  @@index([status])
  @@index([email])
}

model Campaign {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  description    String?   @db.Text
  emailTemplate  String    @db.Text
  subject        String
  status         String    @default("draft")
  scheduledStart DateTime?
  scheduledEnd   DateTime?
  metrics        Json      @default("{}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  leads CampaignLead[]

  @@index([tenantId])
  @@index([status])
}

model CampaignLead {
  id                  String    @id @default(cuid())
  campaignId          String
  campaign            Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  leadId              String
  lead                Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  status              String    @default("pending")
  sentAt              DateTime?
  openedAt            DateTime?
  repliedAt           DateTime?
  personalizedContent String?   @db.Text
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([campaignId, leadId])
  @@index([campaignId])
  @@index([leadId])
}

// ==================== SYSTEM ====================

model Activity {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String
  entityType String
  entityId   String
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  // Phase 3 扩展
  eventCategory String?  // "knowledge"|"marketing"|"review"|"chat"|"system"
  severity      String?  // "info"|"warn"|"error"
  context       Json?    // { versionId, briefId, previousStatus, ... }

  @@index([tenantId])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ==================== MODULE 6: KNOWLEDGE ENGINE ====================

// ==================== ENUMS (Knowledge) ====================

enum EvidenceType {
  claim
  statistic
  testimonial
  case_study
  certification
}

enum GuidelineCategory {
  tone
  terminology
  visual
  messaging
}

// ==================== Phase 3: Artifact Versioning ====================

enum ArtifactStatus {
  draft
  in_review
  client_feedback
  revised
  approved
  published   // UI隐藏，后续启用
  archived
}

model CompanyProfile {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // 企业基本信息（AI提炼）
  companyName  String?
  companyIntro String? @db.Text

  // 核心能力画像
  coreProducts    Json @default("[]") // 核心产品/服务能力
  techAdvantages  Json @default("[]") // 技术优势
  scenarios       Json @default("[]") // 适用场景/行业
  differentiators Json @default("[]") // 差异化卖点

  // 目标客户画像 (ICP)
  targetIndustries Json @default("[]") // 目标行业
  targetRegions    Json @default("[]") // 目标地区
  buyerPersonas    Json @default("[]") // 买家角色
  painPoints       Json @default("[]") // 客户痛点
  buyingTriggers   Json @default("[]") // 购买触发因素

  // AI 分析元数据
  lastAnalyzedAt DateTime?
  analysisSource Json    @default("[]") // 分析使用的素材ID列表
  aiModel        String? // 使用的AI模型
  rawAnalysis    String? @db.Text // AI原始分析结果

  // Phase 2 扩展
  sectionEdits   Json    @default("{}") // { sectionKey: { content, editedAt, editedBy } }
  evidenceRefs   Json    @default("{}") // { sectionKey: string[] }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// ==================== MODULE 5: ASSET HUB ====================

model AssetFolder {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  parentId    String?
  parent      AssetFolder?  @relation("FolderTree", fields: [parentId], references: [id])
  children    AssetFolder[] @relation("FolderTree")
  color       String?
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  assets Asset[]

  @@unique([tenantId, name, parentId])
  @@index([tenantId])
  @@index([parentId])
}

model Asset {
  id           String       @id @default(cuid())
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User         @relation(fields: [uploadedById], references: [id])
  folderId     String?
  folder       AssetFolder? @relation(fields: [folderId], references: [id])

  // 文件信息
  originalName String
  storageKey   String
  mimeType     String
  fileSize     BigInt
  extension    String

  // 分类
  fileCategory String   // video | image | document | audio | other
  purpose      String[] // knowledge | marketing | reference
  tags         String[]

  // 内容
  title       String
  description String?
  metadata    Json     @default("{}")

  // 状态
  status    String    @default("uploading") // uploading | active | archived | deleted
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  chunks    AssetChunk[]

  @@index([tenantId])
  @@index([tenantId, fileCategory])
  @@index([tenantId, status])
  @@index([folderId])
  @@index([uploadedById])
  @@index([createdAt])
}

// ==================== ASSET CHUNKS (文本分块) ====================

model AssetChunk {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  content    String   @db.Text
  chunkIndex Int
  pageNumber Int?
  charStart  Int?
  charEnd    Int?
  tokenCount Int?

  createdAt  DateTime @default(now())

  evidences  Evidence[]

  @@index([assetId])
  @@index([tenantId])
  @@index([assetId, chunkIndex])
}

// ==================== EVIDENCE (证据库) ====================

model Evidence {
  id            String       @id @default(cuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title         String
  content       String       @db.Text
  type          EvidenceType @default(claim)
  sourceLocator Json         @default("{}")
  chunkId       String?
  chunk         AssetChunk?  @relation(fields: [chunkId], references: [id], onDelete: SetNull)
  assetId       String?
  tags          String[]
  status        String       @default("active")
  metadata      Json         @default("{}")
  createdById   String
  createdBy     User         @relation(fields: [createdById], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  @@index([tenantId])
  @@index([tenantId, type])
  @@index([chunkId])
  @@index([assetId])
}

// ==================== BRAND GUIDELINES (品牌规范) ====================

model BrandGuideline {
  id        String            @id @default(cuid())
  tenantId  String
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category  GuidelineCategory
  title     String
  content   String            @db.Text
  examples  Json              @default("[]")
  isActive  Boolean           @default(true)
  order     Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([tenantId])
  @@index([tenantId, category])
}

// ==================== ICP & PERSONA (画像中心) ====================

model ICPSegment {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  industry    String?
  companySize String?
  regions     String[]
  description String?   @db.Text
  criteria    Json      @default("{}")
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  personas    Persona[]

  @@index([tenantId])
}

model Persona {
  id              String        @id @default(cuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  segmentId       String?
  segment         ICPSegment?   @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  name            String
  title           String
  seniority       String?
  concerns        String[]
  messagingPrefs  Json          @default("{}")
  evidenceRefs    String[]
  order           Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  messagingMatrix MessagingMatrix[]
  contentBriefs   ContentBrief[]

  @@index([tenantId])
  @@index([segmentId])
}

model MessagingMatrix {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  personaId    String
  persona      Persona  @relation(fields: [personaId], references: [id], onDelete: Cascade)
  valueProp    String
  message      String   @db.Text
  channel      String?
  evidenceRefs String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
  @@index([personaId])
}

// ==================== Phase 3: ARTIFACT VERSIONING ====================

model ArtifactVersion {
  id          String         @id @default(cuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entityType  String         // "CompanyProfile"|"Evidence"|"BrandGuideline"|"Persona"|"ContentBrief"|"SeoContent"
  entityId    String
  version     Int            // 从 1 自增
  status      ArtifactStatus @default(draft)
  content     Json           // 实体完整快照
  meta        Json           @default("{}") // { changeNote, generatedBy: "ai"|"human", wordCount }
  createdById String
  createdBy   User           @relation(fields: [createdById], references: [id])
  createdAt   DateTime       @default(now())

  comments ArtifactComment[]
  tasks    ArtifactTask[]

  @@unique([entityType, entityId, version])
  @@index([tenantId])
  @@index([entityType, entityId])
  @@index([tenantId, status])
}

// ==================== Phase 3: CONTENT BRIEF ====================

model ContentBrief {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title           String
  targetPersonaId String?
  targetPersona   Persona?  @relation(fields: [targetPersonaId], references: [id], onDelete: SetNull)
  targetKeywords  String[]
  intent          String    // "informational"|"commercial"|"transactional"|"navigational"
  cta             String?
  evidenceIds     String[]  // 引用的 Evidence id 列表
  notes           String?   @db.Text
  status          String    @default("draft") // "draft"|"ready"|"in_progress"|"done"
  createdById     String
  createdBy       User      @relation(fields: [createdById], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  contentPieces SeoContent[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([targetPersonaId])
}

// ==================== Phase 3: ARTIFACT COLLABORATION ====================

model ArtifactComment {
  id         String           @id @default(cuid())
  tenantId   String
  versionId  String
  version    ArtifactVersion  @relation(fields: [versionId], references: [id], onDelete: Cascade)
  content    String           @db.Text
  authorId   String
  author     User             @relation(fields: [authorId], references: [id])
  parentId   String?
  parent     ArtifactComment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies    ArtifactComment[] @relation("CommentReplies")
  resolvedAt DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  // Phase 3 协作壳：锚点定位
  anchorType   String?   // "jsonPath"|"textRange"|"blockId"|"rowId"
  anchorValue  String?   // e.g. "coreProducts[0]", "block-uuid-xxx"
  anchorLabel  String?   // 人类可读标签，如"核心产品·第1项"

  // 评论转任务关联
  linkedTask   ArtifactTask? @relation("CommentTask")

  @@index([versionId])
  @@index([tenantId])
  @@index([parentId])
}

model ArtifactTask {
  id          String           @id @default(cuid())
  tenantId    String
  versionId   String
  version     ArtifactVersion  @relation(fields: [versionId], references: [id], onDelete: Cascade)
  title       String
  assigneeId  String?
  assignee    User?            @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  status      String           @default("open") // "open"|"in_progress"|"done"|"cancelled"
  priority    String           @default("normal") // "urgent"|"normal"|"low"
  dueDate     DateTime?
  createdById String
  createdBy   User             @relation("TaskCreator", fields: [createdById], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // Phase 3 协作壳：来源评论关联
  sourceCommentId String?          @unique
  sourceComment   ArtifactComment? @relation("CommentTask", fields: [sourceCommentId], references: [id], onDelete: SetNull)

  @@index([versionId])
  @@index([tenantId, status])
  @@index([assigneeId])
}

// ==================== Phase 3: DECISION CENTER CHAT ====================

model ChatConversation {
  id              String        @id @default(cuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String?
  contextSnapshot Json?         // debug 用：记录构建时的上下文摘要
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  messages ChatMessage[]

  @@index([tenantId, userId])
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String           // "user"|"assistant"|"system"
  content        String           @db.Text
  references     Json?            // [{ evidenceId, title, excerpt }]
  tokens         Int?
  createdAt      DateTime         @default(now())

  @@index([conversationId, createdAt])
}

// ==================== MODULE 7: RADAR (获客雷达) ====================

// ==================== ENUMS (Radar) ====================

enum ChannelType {
  TENDER      // 招标/采购
  MAPS        // 地图 POI
  DIRECTORY   // 行业名录/协会
  TRADESHOW   // 展会
  HIRING      // 招聘信号
  ECOSYSTEM   // 生态伙伴
  CUSTOM      // 自定义
}

enum AdapterType {
  API           // 官方 REST/GraphQL API
  RSS           // RSS/Atom feed
  AI_SEARCH     // AI + 搜索引擎
  CSV_IMPORT    // CSV 导入
  MANUAL        // 手动录入
}

enum RadarStoragePolicy {
  ID_ONLY           // 只存 ID，详情按需拉取
  TTL_CACHE         // 缓存 N 天后清理
  SNAPSHOT_IMPORT   // 导入时快照永久存储
}

enum CandidateType {
  COMPANY      // 公司
  OPPORTUNITY  // 机会（招标/项目）
  CONTACT      // 联系人
}

enum CandidateStatus {
  NEW          // 新发现
  REVIEWING    // 审核中
  QUALIFIED    // 已合格化
  IMPORTED     // 已导入线索库
  EXCLUDED     // 已排除
  EXPIRED      // 已过期
}

enum RadarTaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum OpportunityStage {
  IDENTIFIED    // 已识别
  QUALIFYING    // 资格评估中
  PURSUING      // 跟进中
  PROPOSAL      // 已提案
  NEGOTIATION   // 谈判中
  WON           // 赢单
  LOST          // 丢单
}

// ==================== 数据源目录 ====================

model RadarSource {
  id              String   @id @default(cuid())
  tenantId        String?  // null = 系统级公共源
  
  // 分类
  channelType     ChannelType
  
  // 基础信息
  name            String
  code            String   @unique
  description     String?
  logoUrl         String?
  websiteUrl      String?
  
  // 覆盖范围
  countries       String[] // ISO codes, 空 = 全球
  regions         String[] // EU | LATAM | MENA | APAC 等
  
  // 接入配置
  adapterType     AdapterType
  adapterConfig   Json     @default("{}") // API endpoint, auth, field mapping 等
  
  // 合规与策略
  isOfficial      Boolean  @default(false)  // 是否官方源
  requiresAuth    Boolean  @default(false)
  termsUrl        String?
  storagePolicy   RadarStoragePolicy @default(TTL_CACHE)
  ttlDays         Int      @default(90)
  attributionRequired Boolean @default(true)
  
  // 速率限制
  rateLimit       Json     @default("{}") // { requests, windowMs }
  
  // 状态
  isEnabled       Boolean  @default(true)
  lastSyncAt      DateTime?
  syncStats       Json?    // { totalFetched, lastError, avgResponseTime }
  
  // 关系
  candidates      RadarCandidate[]
  tasks           RadarTask[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([channelType, isEnabled])
}

// ==================== 发现任务 ====================

model RadarTask {
  id              String   @id @default(cuid())
  tenantId        String
  
  // 任务配置
  name            String?
  sourceId        String
  source          RadarSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  
  // 画像引用（可追溯）
  targetingRef    Json?    // { segmentId?, personaId?, specVersionId? }
  channelMapRef   String?  // 引用 ArtifactVersion id
  
  // 查询计划
  queryConfig     Json     // 搜索参数：keywords, categories, regions, dateRange
  
  // 执行状态
  status          RadarTaskStatus @default(PENDING)
  startedAt       DateTime?
  completedAt     DateTime?
  cancelToken     String?
  
  // 统计
  stats           Json?    // { fetched, new, duplicate, errors, duration }
  errorMessage    String?
  
  // 触发方式
  triggeredBy     String   // userId | "scheduler" | "manual"
  scheduleRule    String?  // cron expression for recurring
  
  // 关系
  candidates      RadarCandidate[]
  
  createdAt       DateTime @default(now())
  
  @@index([tenantId, status])
  @@index([sourceId, status])
}

// ==================== 统一候选池 ====================

model RadarCandidate {
  id              String   @id @default(cuid())
  tenantId        String
  
  // 来源追溯（必须）
  sourceId        String
  source          RadarSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  taskId          String?
  task            RadarTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  
  // 候选类型
  candidateType   CandidateType
  
  // 外部标识
  externalId      String   // place_id, notice_id, etc.
  sourceUrl       String   // 必须有，用于追溯
  
  // 通用字段
  displayName     String
  description     String?  @db.Text
  
  // 公司字段（candidateType=COMPANY）
  website         String?
  phone           String?
  email           String?
  address         String?
  country         String?
  city            String?
  industry        String?
  companySize     String?
  
  // 机会字段（candidateType=OPPORTUNITY，即招标）
  deadline        DateTime?
  estimatedValue  Float?
  currency        String?
  buyerName       String?
  buyerCountry    String?
  buyerType       String?  // government | enterprise | ngo | international_org
  categoryCode    String?  // CPV / UNSPSC
  categoryName    String?
  
  // 联系人字段（candidateType=CONTACT）
  contactRole     String?
  linkedCandidateId String? // 关联到哪个公司候选
  
  // ICP 匹配（核心）
  matchScore      Float?
  matchExplain    Json?    // { rules: [...], reasons: [...], query, channel }
  
  // AI 处理
  aiSummary       String?  @db.Text
  aiRelevance     Json?    // { score, reasons[], matchedKeywords[] }
  
  // 状态
  status          CandidateStatus @default(NEW)
  qualifyTier     String?  // A | B | C | excluded
  qualifyReason   String?
  qualifiedAt     DateTime?
  qualifiedBy     String?
  
  // 导入追踪
  importedToType  String?  // ProspectCompany | Opportunity
  importedToId    String?
  importedAt      DateTime?
  importedBy      String?
  
  // TTL 策略
  rawData         Json?
  expireAt        DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([sourceId, externalId])
  @@index([tenantId, candidateType, status])
  @@index([tenantId, qualifyTier])
  @@index([tenantId, sourceId])
  @@index([taskId])
  @@index([expireAt])
}

// ==================== 正式线索公司 ====================

model ProspectCompany {
  id              String   @id @default(cuid())
  tenantId        String
  
  // 公司信息
  name            String
  website         String?
  phone           String?
  email           String?
  address         String?
  country         String?
  city            String?
  industry        String?
  companySize     String?
  description     String?  @db.Text
  
  // 分类与标签
  tier            String?  // A | B | C
  tags            String[]
  
  // 来源追溯
  sourceType      String?  // tender | maps | directory | tradeshow | hiring | manual
  sourceCandidateId String? // 来自哪个候选
  sourceUrl       String?
  
  // 跟进状态
  status          String   @default("new") // new | contacted | qualified | converted | lost
  assignedTo      String?
  lastContactedAt DateTime?
  nextActionDate  DateTime?
  notes           String?  @db.Text
  
  // 关系
  contacts        ProspectContact[]
  opportunities   Opportunity[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
  
  @@index([tenantId, status])
  @@index([tenantId, tier])
  @@index([tenantId, industry])
  @@index([assignedTo])
}

// ==================== 正式联系人 ====================

model ProspectContact {
  id              String   @id @default(cuid())
  tenantId        String
  
  // 关联公司
  companyId       String?
  company         ProspectCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  
  // 联系人信息
  name            String
  email           String?
  phone           String?
  role            String?
  department      String?
  seniority       String?  // C-level | VP | Director | Manager | Staff
  linkedInUrl     String?
  
  // 来源
  sourceCandidateId String?
  sourceUrl       String?
  
  // 状态
  status          String   @default("new")
  notes           String?  @db.Text
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
  
  @@index([tenantId, companyId])
  @@index([tenantId, status])
  @@index([email])
}

// ==================== 正式机会（招标转化后） ====================

model Opportunity {
  id              String   @id @default(cuid())
  tenantId        String
  
  // 关联公司
  companyId       String?
  company         ProspectCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  
  // 来源
  sourceType      String   // tender | project | referral | inbound
  sourceCandidateId String?
  sourceUrl       String?
  
  // 核心信息
  title           String
  description     String?  @db.Text
  
  // 时间与金额
  deadline        DateTime?
  estimatedValue  Float?
  currency        String?
  
  // 分类
  categoryCode    String?
  categoryName    String?
  
  // 阶段管理
  stage           OpportunityStage @default(IDENTIFIED)
  probability     Int?     // 0-100
  lostReason      String?
  wonAt           DateTime?
  lostAt          DateTime?
  
  // 跟进
  assignedTo      String?
  nextAction      String?
  nextActionDate  DateTime?
  notes           String?  @db.Text
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
  
  @@index([tenantId, stage])
  @@index([tenantId, deadline])
  @@index([companyId])
  @@index([assignedTo])
}

// ==================== 搜索配置（定时监控） ====================

model RadarSearchProfile {
  id              String   @id @default(cuid())
  tenantId        String
  
  name            String
  description     String?
  
  // 关联画像
  segmentId       String?  // 关联 ICPSegment
  personaId       String?  // 关联 Persona
  
  // 搜索配置
  keywords        Json     @default("{}") // { en: [], zh: [], es: [], ar: [] }
  negativeKeywords Json?   // 排除词
  
  // 目标区域
  targetCountries String[]
  targetRegions   String[]
  
  // 行业/分类过滤
  industryCodes   String[]
  categoryFilters String[] // CPV/UNSPSC codes
  
  // 渠道配置
  enabledChannels ChannelType[]
  sourceIds       String[] // 指定的 source ids
  
  // 调度
  isActive        Boolean  @default(true)
  scheduleRule    String   @default("0 6 * * *") // 默认每天早6点
  lastRunAt       DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([tenantId, isActive])
}
