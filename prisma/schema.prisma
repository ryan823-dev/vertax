  lastRunAt    DateTime?

  // === йҺёдҪәз”»йҺөоӮЈејҝеҜ®жӣҹжҗё ===
  nextRunAt      DateTime? // жЈ°еӢ®о…ёз» жӨҫз¬…еЁҶВӨз№ҚзҗӣеұҫжӨӮй—Ӯиҫҫзҙҷз»ұгҲ зҙ©йҸҢгғЁоҮ—й”ӣ?
  lockToken      String? // ж¶”ж„ҜоқҮй–ҝ?UUID
  lockedAt       DateTime? // й–ҝдҪёз•ҫйҸғе •жЈҝй”ӣ?йҚ’е—ӣжҢ“з“’е‘®жӨӮй–Іе©ғж–Ғй”ӣ?
  lockedBy       String? // Vercel зҖ№зӮ°з·ҘйҸҚеӣӘзҳ‘
  maxRunSeconds  Int       @default(45) // йҚ—жӣҹоӮјйҺөоӮЈејҝжЈ°еӢӯз•»й”ӣе ўжҡҖ15sзјҒ?0s timeoutй”ӣ?
  autoQualify    Boolean   @default(true) // й‘·оҒ„е§©з‘ҷп№ҖеҪӮ AI йҚҡе ҹзүёйҚ–?
  autoEnrich     Boolean   @default(false) // й‘·оҒ„е§©з‘ҷп№ҖеҪӮз’ҮпёҪе„ҸзҗӣгғҘеҸҸ
  runStats       Json? // { totalRuns, totalNew, lastError, avgDurationMs }
  exclusionRules Json? // жө ?rejected йҚҷе¶…жӮңзҖӣпёҝзҜ„йҗЁеӢ¬её“й—„гӮҲзҳқ

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== йҺөоӮЈејҝеЁ“е‘ҠзҲЈй”ӣе ҹеҜ”зјҒо…һо–ғй–ІеҝҘзҙҡ ====================

model RadarScanCursor {
