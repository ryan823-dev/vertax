// ==================== Phase 3: ARTIFACT VERSIONING ====================

model ArtifactVersion {
  id          String         @id @default(cuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entityType  String // "CompanyProfile"|"Evidence"|"BrandGuideline"|"Persona"|"ContentBrief"|"SeoContent"
  entityId    String
  version     Int // жө ?1 й‘·оҒ„о–ғ
  status      ArtifactStatus @default(draft)
  content     Json // зҖ№зӮ°з¶ӢзҖ№еұҫжҡЈи№ҮоӮӨеҸҺ
  meta        Json           @default("{}") // { changeNote, generatedBy: "ai"|"human", wordCount }
  createdById String
  createdBy   User           @relation(fields: [createdById], references: [id])
  createdAt   DateTime       @default(now())

  comments ArtifactComment[]
  tasks    ArtifactTask[]

  @@unique([entityType, entityId, version])
}

// ==================== Phase 3: CONTENT BRIEF ====================

model ContentBrief {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title           String
  targetPersonaId String?
  targetPersona   Persona?  @relation(fields: [targetPersonaId], references: [id], onDelete: SetNull)
  targetKeywords  String[]
  intent          String // "informational"|"commercial"|"transactional"|"navigational"
  cta             String?
  evidenceIds     String[] // еҜ®жӣ ж•ӨйҗЁ?Evidence id йҚ’жҘ„гҖғ
  notes           String?
  status          String    @default("draft") // "draft"|"ready"|"in_progress"|"done"
  createdById     String
  createdBy       User      @relation(fields: [createdById], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  contentPieces SeoContent[]
}

// ==================== Phase 3: ARTIFACT COLLABORATION ====================

model ArtifactComment {
  id         String            @id @default(cuid())
  tenantId   String
  versionId  String
  version    ArtifactVersion   @relation(fields: [versionId], references: [id], onDelete: Cascade)
  content    String
  authorId   String
  author     User              @relation(fields: [authorId], references: [id])
  parentId   String?
  parent     ArtifactComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies    ArtifactComment[] @relation("CommentReplies")
  resolvedAt DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  // Phase 3 йҚ—еҝҺз¶”жҫ№зӯ№зҙ°й–ҝж°ұеҒЈзҖ№ж°«з¶…
  anchorType  String? // "jsonPath"|"textRange"|"blockId"|"rowId"
  anchorValue String? // e.g. "coreProducts[0]", "block-uuid-xxx"
  anchorLabel String? // жөңиҷ№иў«йҚҷоҲқоҮ°йҸҚеӣ©о„·й”ӣеұҪоӣ§"йҸҚзЁҝзёҫжөңСғжҗ§и·Ҝз»—?жӨӨ?

  // з’ҮеӢ®оҶ‘жқһоғҝжҚўйҚ”вҖіеҸ§й‘ұ?
  linkedTask ArtifactTask? @relation("CommentTask")
}

model ArtifactTask {
  id          String          @id @default(cuid())
  tenantId    String
  versionId   String
  version     ArtifactVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  title       String
  assigneeId  String?
  assignee    User?           @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  status      String          @default("open") // "open"|"in_progress"|"done"|"cancelled"
  priority    String          @default("normal") // "urgent"|"normal"|"low"
  dueDate     DateTime?
  createdById String
  createdBy   User            @relation("TaskCreator", fields: [createdById], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Phase 3 йҚ—еҝҺз¶”жҫ№зӯ№зҙ°йҸүгғҰз°®з’ҮеӢ®оҶ‘йҚҸе® д»Ҳ
  sourceCommentId String?          @unique
  sourceComment   ArtifactComment? @relation("CommentTask", fields: [sourceCommentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

// ==================== Phase 3: DECISION CENTER CHAT ====================

model ChatConversation {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String?
  contextSnapshot Json? // debug йҗўоҹ’зҙ°з’Ғжқҝз¶ҚйҸӢеӢ«зј“йҸғеүҒж®‘ж¶“е©Ғз¬…йҸӮеӣЁжҶіз‘•?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  messages ChatMessage[]
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // "user"|"assistant"|"system"
  content        String
  references     Json? // [{ evidenceId, title, excerpt }]
  tokens         Int?
  createdAt      DateTime         @default(now())
}

// ==================== MODULE 7: RADAR (й‘ҫеі°о…№й—Ҷз–ҜжҸӘ) ====================

// ==================== ENUMS (Radar) ====================

enum ChannelType {
  TENDER // йҺ·ж¶ҷзҲЈ/й–ІеӣӘе–ҳ
  MAPS // йҚҰжқҝжөҳ POI
  DIRECTORY // зҗӣеұјз¬ҹйҚҡе¶…з¶Қ/йҚ—еҝҺзҙ°
  TRADESHOW // зҒһжӣҡзҙ°
  HIRING // йҺ·ж¶ңд»’ж·ҮвҖіеҪҝ
  ECOSYSTEM // йҗўзҶёвӮ¬дҪ·зҙ®жөј?
  CUSTOM // й‘·оҒ„з•ҫж¶”?
}

enum AdapterType {
  API // зҖ№жЁ»жҹҹ REST/GraphQL API
  RSS // RSS/Atom feed
  AI_SEARCH // AI + йҺјж»…еӮЁеҜ®жӣҹжҗё
  CSV_IMPORT // CSV зҖөз…ҺеҸҶ
  MANUAL // йҺөе¬Әе§©иӨ°жӣһеҸҶ
}

enum RadarStoragePolicy {
  ID_ONLY // йҚҷоҒ„з“Ё IDй”ӣеІғоҮӣйҺҜе‘®еҜңй—ҮвӮ¬йҺ·еӨҠеҪҮ
  TTL_CACHE // зјӮж’із“Ё N жҫ¶в•ҒжӮ—еЁ“е‘ҜжӮҠ
  SNAPSHOT_IMPORT // зҖөз…ҺеҸҶйҸғи·әжҸ©йҗ“С„жЎҲж¶”е‘ӯз“ЁйҚҢ?
}

enum CandidateType {
  COMPANY // йҚҸо„Җеҫғ
  OPPORTUNITY // йҸҲиҪ°зҙ°й”ӣе ҹе«‘йҸҚ?жӨӨеңӯжҙ°й”ӣ?
  CONTACT // й‘ұж—Ӯйғҙжөң?
}

enum CandidateStatus {
  NEW // йҸӮжқҝеҪӮйҗң?
  REVIEWING // зҖ№в„ғзүіж¶“?
  QUALIFIED // е®ёжҸ’жӮҺйҸҚз…ҺеҜІ
  IMPORTED // е®ёжҸ’оҮұйҚҸгғ§еҡҺз»ұгҲ з°ұ
  EXCLUDED // е®ёеҸүеё“й—„?
  EXPIRED // е®ёиҢ¶з№ғйҸҲ?
  ENRICHING // з»ӣеӨҠз·ҹ getDetails() зҗӣгғҘеҸҸ
}

enum RadarTaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum OpportunityStage {
  IDENTIFIED // е®ёиҢ¶зҳ‘йҚ’?
  QUALIFYING // з’§еӢ¬зүёз’ҮеӢӘеҸҠж¶“?
  PURSUING // з’әзҶ»з№ҳж¶“?
  PROPOSAL // е®ёеҸүеҪҒеҰ—?
  NEGOTIATION // з’Ӣе қеһҪж¶“?
  WON // з’§гҲ еҙҹ
  LOST // ж¶“гҲ еҙҹ
}

// ==================== йҸҒзүҲеөҒе©§ж„®жҙ°иӨ°?====================

model RadarSource {
  id       String  @id @default(cuid())
  tenantId String? // null = з»ҜиҚӨзІәз»ҫСғеҸ•йҚҸиҫЁз°®

  // йҚ’е—ҷиў«
  channelType ChannelType

  // йҚ©иҷ№о”…ж·Үв„ғдј…
  name        String
  code        String  @unique
  description String?
  logoUrl     String?
  websiteUrl  String?

  // з‘•е—ҷжҙҠй‘јеҶЁжҙҝ
  countries String[] // ISO codes, з»Ң?= йҚҸг„§жӮҶ
  regions   String[] // EU | LATAM | MENA | APAC з»ӣ?

  // йҺәгғҘеҸҶй–°е¶Үз–Ҷ
  adapterType   AdapterType
  adapterConfig Json        @default("{}") // API endpoint, auth, field mapping з»ӣ?

  // йҚҡе Јоқүж¶“еәЈз“ҘйҗЈ?
  isOfficial          Boolean            @default(false) // йҸ„оҲҡжғҒзҖ№жЁ»жҹҹе©§?
  requiresAuth        Boolean            @default(false)
  termsUrl            String?
  storagePolicy       RadarStoragePolicy @default(TTL_CACHE)
  ttlDays             Int                @default(90)
  attributionRequired Boolean            @default(true)

  // й–«зҶәе·јй—„ж„¬еҹ—
  rateLimit Json @default("{}") // { requests, windowMs }

  // йҗҳиҲөвӮ¬?
  isEnabled  Boolean   @default(true)
  lastSyncAt DateTime?
  syncStats  Json? // { totalFetched, lastError, avgResponseTime }

  // йҚҸеҙҮйғҙ
  candidates RadarCandidate[]
  tasks      RadarTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== йҚҷжҲ е№Үжө иҜІе§ҹ ====================

model RadarTask {
  id       String @id @default(cuid())
  tenantId String

  // жө иҜІе§ҹй–°е¶Үз–Ҷ
  name     String?
  sourceId String
  source   RadarSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  // йҗўиҜІе„ҡеҜ®жӣ ж•Өй”ӣе қеҪІжқ©иҠҘеҮҪй”ӣ?
  targetingRef  Json? // { segmentId?, personaId?, specVersionId? }
  channelMapRef String? // еҜ®жӣ ж•Ө ArtifactVersion id

  // йҸҢгғЁоҮ—з’ҒвҖіеһқ
  queryConfig Json // йҺјж»…еӮЁйҚҷеӮӣжҡҹй”ӣжӯ¬eywords, categories, regions, dateRange

  // йҺөСҶо”‘йҗҳиҲөвӮ¬?
  status      RadarTaskStatus @default(PENDING)
  startedAt   DateTime?
  completedAt DateTime?
  cancelToken String?

  // зјҒзҶ»о…ё
  stats        Json? // { fetched, new, duplicate, errors, duration }
  errorMessage String?

  // з‘ҷп№ҖеҪӮйҸӮз‘°зҙЎ
  triggeredBy  String // userId | "scheduler" | "manual"
  scheduleRule String? // cron expression for recurring

  // йҚҸеҙҮйғҙ
  candidates RadarCandidate[]

  createdAt DateTime @default(now())
}

// ==================== зјҒзҶ¶з«ҙйҚҠж¬“вӮ¬еӨӢзқң ====================

model RadarCandidate {
  id       String @id @default(cuid())
  tenantId String

  // йҸүгғҰз°®жқ©иҠҘеҮҪй”ӣе қз№ҖжӨӨдјҷзҙҡ
  sourceId String
  source   RadarSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  taskId   String?
  task     RadarTask?  @relation(fields: [taskId], references: [id], onDelete: SetNull)

  // йҚҠж¬“вӮ¬еӨҢиў«йҚЁ?
  candidateType CandidateType

  // жҫ¶ж ӯе„ҙйҸҚеӣӘзҳ‘
  externalId String // place_id, notice_id, etc.
  sourceUrl  String // и№Үе‘ҙгҖҸйҸҲеӨӣзҙқйҗўг„Өз°¬жқ©иҠҘеҮҪ

  // й–«ж°ұж•ӨзҖӣжҘҒоҶҢ
  displayName String
  description String?

  // йҚҸо„ҖеҫғзҖӣжҘҒоҶҢй”ӣеқҲandidateType=COMPANYй”ӣ?
  website     String?
  phone       String?
  email       String?
  address     String?
  country     String?
  city        String?
  industry    String?
  companySize String?

  // йҸҲиҪ°зҙ°зҖӣжҘҒоҶҢй”ӣеқҲandidateType=OPPORTUNITYй”ӣеұҪеөҶйҺ·ж¶ҷзҲЈй”ӣ?
  deadline       DateTime?
  estimatedValue Float?
  currency       String?
  buyerName      String?
  buyerCountry   String?
  buyerType      String? // government | enterprise | ngo | international_org
  categoryCode   String? // CPV / UNSPSC
  categoryName   String?

  // й‘ұж—Ӯйғҙжөңе“„з“§еЁҲзўүзҙҷcandidateType=CONTACTй”ӣ?
  contactRole       String?
  linkedInUrl       String? // йҚҸо„Җеҫғ LinkedIn жӨӨзӨ¬uff08Exa ж¶“жқҝзҳңйҚ–ж §е•“йҚҸоҷўuff09
  linkedCandidateId String? // йҚҸе® д»ҲйҚ’жқҝж‘ўж¶“оҒ„еҸ•йҚҷзЁҝвӮ¬ж¬“вӮ¬?

  // ICP йҚ–еҪ’еҺӨй”ӣе ҹзүіи№ҮеҶҝзҙҡ
  matchScore   Float?
  matchExplain Json? // { rules: [...], reasons: [...], query, channel }

  // AI жҫ¶еӢӯжӮҠ
  aiSummary   String?
  aiRelevance Json? // { score, reasons[], matchedKeywords[] }

  // йҗҳиҲөвӮ¬?
  status        CandidateStatus @default(NEW)
  qualifyTier   String? // A | B | C | excluded
  qualifyReason String?
  qualifiedAt   DateTime?
  qualifiedBy   String?

  // зҖөз…ҺеҸҶжқ©еҖҹйҮң
  importedToType String? // ProspectCompany | Opportunity
  importedToId   String?
  importedAt     DateTime?
  importedBy     String?

  // йҺёдҪәз”»йҺөоӮЈејҝйҚҸе® д»Ҳ
  profileId   String? // з‘ҷп№ҖеҪӮз’ҮгғҘвӮ¬ж¬“вӮ¬еӨҢж®‘ SearchProfile
  publishedAt DateTime? // йҺ·ж¶ҷзҲЈйҚҷжҲқз«·йҸғе •жЈҝй”ӣе ңзІ  source й‘ҫеі°еҪҮй”ӣ?
  enrichedAt  DateTime? // з’ҮпёҪе„ҸзҗӣгғҘеҸҸзҖ№еұҫеһҡйҸғе •жЈҝ

  // TTL з»ӣж «жҡҗ
  rawData  Json?
  expireAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contentLinks RadarContentLink[] // й‘ҫеі°о…№й—Ҷз–ҜжҸӘйҚҗе‘ӯоҶҗй‘ұж–ҝе§©

  @@unique([sourceId, externalId])
}

// ==================== е§қпҪ…зҙЎз»ҫи·ЁеӮЁйҚҸо„Җеҫғ ====================

model ProspectCompany {
  id       String @id @default(cuid())
  tenantId String

  // йҚҸо„Җеҫғж·Үв„ғдј…
  name        String
  website     String?
  phone       String?
  email       String?
  address     String?
  country     String?
  city        String?
  industry    String?
  companySize String?
    description String?

