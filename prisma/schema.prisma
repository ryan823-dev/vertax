  sourceCandidateId String? // йҸүгғЁеҡңйҚқоҒғйҮңйҚҠж¬“вӮ¬?
  sourceUrl         String?

  // з’әзҶ»з№ҳйҗҳиҲөвӮ¬?
  status          String    @default("new") // new | contacted | qualified | converted | lost
