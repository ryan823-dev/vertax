generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== TENANT & AUTH ====================
// ==================== TENANT & AUTH ====================

model Tenant {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  domain      String?
  plan        String    @default("free")
  status      String    @default("active")
  settings    Json      @default("{}")
  emailConfig Json? // 閭欢閰嶇疆锛氬钩鍙癒ey/鑷畾涔塊ey銆佸彂浠跺煙鍚嶇瓑
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  users              User[]
  products           Product[]
  seoContents        SeoContent[]
  seoAudits          SeoAudit[]
  socialPosts        SocialPost[]
  socialAccounts     SocialAccount[]
  leads              Lead[]
  campaigns          Campaign[]
  categories         ContentCategory[]
  websiteConfigs     WebsiteConfig[]
  activities         Activity[]
  notifications      Notification[]
  assetFolders       AssetFolder[]
  assets             Asset[]
  apiKeys            ApiKey[]
  companyProfile     CompanyProfile?
  assetChunks        AssetChunk[]
  evidences          Evidence[]
  brandGuidelines    BrandGuideline[]
  icpSegments        ICPSegment[]
  personas           Persona[]
  messagingMatrices  MessagingMatrix[]
  // Phase 3
  artifactVersions   ArtifactVersion[]
  contentBriefs      ContentBrief[]
  chatConversations  ChatConversation[]
  prospectCompanies  ProspectCompany[]
  radarDailySnapshots RadarDailySnapshot[]
  // Web crawl queue
  crawlQueues        CrawlQueue[]
  // Asset processing queue
  assetProcessQueues AssetProcessQueue[]
}

model WebsiteConfig {
  id              String  @id @default(cuid())
  tenantId        String
  tenant          Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  siteName        String? // 鐩爣绔欏悕绉帮紙澶氱珯鍖哄垎锛?
  url             String?
  apiKey          String?
  publishEndpoint String?
  seoDefaults     Json    @default("{}")

  // === Publishing Pipeline 鎵╁睍 ===
  siteType             String  @default("supabase") // supabase | nextjs | wordpress | rest
  supabaseUrl          String? // [supabase] e.g. "https://xxx.supabase.co"
  functionName         String? // [supabase] e.g. "receive-content-push"
  webhookUrl           String? // [nextjs | rest] 瀹㈡埛绔欐帴鏀?endpoint
  wpUrl                String? // [wordpress] WP 绔欑偣鏍?URL
  wpUsername           String? // [wordpress] WP 鐢ㄦ埛鍚?
  wpPassword           String? // [wordpress] Application Password
  pushSecret           String? // 鍏变韩瀵嗛挜锛圚MAC绛惧悕 / Bearer token锛?
  customHeaders        Json? // 鑷畾涔夎姹傚ご锛坮est/nextjs 鐢級
  fieldMapping         Json    @default("{}") // Vertax 鈫?鐩爣绔欏瓧娈垫槧灏?
  approvalTimeoutHours Int     @default(24)
  isActive             Boolean @default(true)

  pushRecords PushRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// ==================== CONTENT PUSH PIPELINE ====================

enum PushStatus {
  PENDING // 宸叉帹閫侊紝绛夊緟瀹㈡埛绔欑偣瀹℃牳
  CONFIRMED // 瀹㈡埛绔欑偣宸茬‘璁ゅ彂甯?
  TIMEOUT // 瓒呮椂鏈‘璁?
  FAILED // 鎺ㄩ€佸け璐?
  ESCALATED // 宸插崌绾у埌杩愯惀澶勭悊
}

model PushRecord {
  id       String @id @default(cuid())
  tenantId String

  // 鍏宠仈鍐呭
  contentId String // SeoContent.id
  content   SeoContent @relation(fields: [contentId], references: [id], onDelete: Cascade)

  // 鐩爣绔欑偣
  websiteConfigId String
  websiteConfig   WebsiteConfig @relation(fields: [websiteConfigId], references: [id], onDelete: Cascade)

  // 鎺ㄩ€佺姸鎬?
  status     PushStatus @default(PENDING)
  remoteId   String? // 鐩爣绔欑偣杩斿洖鐨勮褰?ID
  remoteSlug String? // 鐩爣绔欑偣鐨?slug
  targetUrl  String? // 鐩爣绔欑偣涓婄殑瀹屾暣 URL

  // 瀛楁蹇収锛堟帹閫佹椂鐨勬槧灏勭粨鏋滐級
  pushPayload     Json? // 瀹為檯鍙戦€佺殑 payload 蹇収
  contentVersion  Int? // 鎺ㄩ€佹椂瀵瑰簲鐨?SeoContent.version
  contentSnapshot Json? // { title, slug, excerpt, keywords } 蹇収

  // 鏃堕棿杩借釜
  pushedAt    DateTime  @default(now())
  timeoutAt   DateTime // pushedAt + approvalTimeoutHours
  confirmedAt DateTime?
  escalatedAt DateTime?

  // 閿欒澶勭悊
  retryCount Int     @default(0)
  lastError  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contentId, websiteConfigId]) // 姣忎釜鍐呭姣忎釜绔欑偣鍙湁涓€鏉℃帹閫佽褰?
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?
  tenantId      String?
  tenant        Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roleId        String
  role          Role      @relation(fields: [roleId], references: [id])
  locale        String    @default("zh-CN")
  timezone      String    @default("Asia/Shanghai")
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  accounts          Account[]
  sessions          Session[]
  seoContents       SeoContent[]
  seoAudits         SeoAudit[]
  socialPosts       SocialPost[]
  ownedLeads        Lead[]
  activities        Activity[]
  assets            Asset[]
  evidences         Evidence[]
  // Phase 3
  artifactVersions  ArtifactVersion[]
  contentBriefs     ContentBrief[]
  artifactComments  ArtifactComment[]
  tasksCreated      ArtifactTask[]     @relation("TaskCreator")
  tasksAssigned     ArtifactTask[]     @relation("TaskAssignee")
  chatConversations ChatConversation[]
}

model Role {
  id           String   @id @default(cuid())
  name         String   @unique
  displayName  String
  permissions  Json
  isSystemRole Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users User[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ApiKey {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  key         String    @unique
  permissions String[]  @default(["assets:write"])
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ==================== MODULE 1: PRODUCTS ====================

model Product {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sku             String?
  name            String
  slug            String
  description     String?
  detailedContent String?
  status          String    @default("draft")
  publishedAt     DateTime?
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  images     ProductImage[]
  specs      ProductSpec[]
  categories ProductCategory[]

  @@unique([tenantId, slug])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  altText   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model ProductSpec {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  key       String
  value     String
  unit      String?
  order     Int     @default(0)
}

model ProductCategory {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String

  @@unique([productId, name])
}

// ==================== MODULE 2: SEO & GEO CONTENT ====================

model SeoAudit {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  targetUrl     String
  status        String    @default("pending")
  progress      Int       @default(0)
  currentStep   String?
  scores        Json      @default("{}")
  findings      Json      @default("[]")
  aiSummary     String?
  crawlErrors   Json      @default("[]")
  pagesCrawled  Int       @default(0)
  crawlDuration Int?
  createdAt     DateTime  @default(now())
  completedAt   DateTime?
}

model ContentCategory {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  description String?
  icon        String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contents SeoContent[]

  @@unique([tenantId, slug])
}

model SeoContent {
  id              String          @id @default(cuid())
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId      String
  category        ContentCategory @relation(fields: [categoryId], references: [id])
  authorId        String
  author          User            @relation(fields: [authorId], references: [id])
  title           String
  slug            String
  excerpt         String?
  content         String
  metaTitle       String?
  metaDescription String?
  keywords        String[]
  featuredImage   String?
  status          String          @default("draft")
  publishedAt     DateTime?
  scheduledAt     DateTime?
  version         Int             @default(1) // 鍐呭鐗堟湰鍙凤紝姣忔淇濆瓨鑷姩 +1
  aiMetadata      Json            @default("{}")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  // Phase 3 鎵╁睍
  briefId          String?
  brief            ContentBrief?           @relation(fields: [briefId], references: [id], onDelete: SetNull)
  outline          Json? // { sections: [{ heading, keyPoints }] }
  evidenceRefs     String[] // 寮曠敤鐨?Evidence id
  schemaJson       Json? // Schema.org 缁撴瀯鍖栨暟鎹?(FAQPage JSON-LD)
  geoVersion       String? // GEO-optimized short version (300-500 words, for AI citation)

  // Auto-publish grace period (24h window for AI-generated content)
  autoPublishAt    DateTime? // Non-null = awaiting publish, cron will auto-publish when reached
  generatedBy      String? // "ai" | "human" | null, marks content origin

  pushRecords      PushRecord[] // 鎺ㄩ€佽褰?
  contentLinks     RadarContentLink[] // 鑾峰闆疯揪鍐呭鑱斿姩
  geoDistributions GeoDistributionRecord[] // GEO 鍒嗗彂杩借釜

  @@unique([tenantId, slug])
  @@index([status, autoPublishAt]) // For auto-publish cron query
}

// ==================== MODULE 3: SOCIAL MEDIA ====================

model SocialAccount {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  platform     String
  accountName  String
  accountId    String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  metadata     Json      @default("{}")
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([tenantId, platform, accountId])
}

model SocialPost {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  authorId     String
  author       User      @relation(fields: [authorId], references: [id])
  title        String?
  status       String    @default("draft")
  scheduledAt  DateTime?
  publishedAt  DateTime?
  autoEngage   Boolean   @default(false)
  engageConfig Json      @default("{}")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  versions PostVersion[]
}

model PostVersion {
  id              String     @id @default(cuid())
  postId          String
  post            SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  platform        String
  content         String
  media           String[]
  platformPostId  String?
  publishedAt     DateTime?
  error           String?
  publishAttempts Int        @default(0)
  metrics         Json       @default("{}")
}

// ==================== MODULE 4: AI LEAD GENERATION ====================

model Lead {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ownerId         String
  owner           User      @relation(fields: [ownerId], references: [id])
  companyName     String
  contactName     String?
  email           String?
  phone           String?
  website         String?
  country         String?
  city            String?
  industry        String?
  companySize     String?
  status          String    @default("new")
  priority        String    @default("medium")
  researchData    Json      @default("{}")
  notes           String?
  lastContactedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  campaigns CampaignLead[]
}

model Campaign {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  emailTemplate  String
  subject        String
  status         String    @default("draft")
  scheduledStart DateTime?
  scheduledEnd   DateTime?
  metrics        Json      @default("{}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  leads CampaignLead[]
}

model CampaignLead {
  id                  String    @id @default(cuid())
  campaignId          String
  campaign            Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  leadId              String
  lead                Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  status              String    @default("pending")
  sentAt              DateTime?
  openedAt            DateTime?
  repliedAt           DateTime?
  personalizedContent String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([campaignId, leadId])
}

// ==================== SYSTEM ====================

model Activity {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String
  entityType String
  entityId   String
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  // Phase 3 鎵╁睍
  eventCategory String? // "knowledge"|"marketing"|"review"|"chat"|"system"
  severity      String? // "info"|"warn"|"error"
  context       Json? // { versionId, briefId, previousStatus, ... }
}

// ==================== MODULE 6: KNOWLEDGE ENGINE ====================

// ==================== ENUMS (Knowledge) ====================

enum EvidenceType {
  claim
  statistic
  testimonial
  case_study
  certification
}

enum GuidelineCategory {
  tone
  terminology
  visual
  messaging
}

// ==================== Phase 3: Artifact Versioning ====================

enum ArtifactStatus {
  draft
  in_review
  client_feedback
  revised
  approved
  published // UI闅愯棌锛屽悗缁惎鐢?
  archived
}

model CompanyProfile {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // 浼佷笟鍩烘湰淇℃伅锛圓I鎻愮偧锛?
  companyName  String?
  companyIntro String?

  // 鏍稿績鑳藉姏鐢诲儚
  coreProducts    Json @default("[]") // 鏍稿績浜у搧/鏈嶅姟鑳藉姏
  techAdvantages  Json @default("[]") // 鎶€鏈紭鍔?
  scenarios       Json @default("[]") // 閫傜敤鍦烘櫙/琛屼笟
  differentiators Json @default("[]") // 宸紓鍖栧崠鐐?

  // 鐩爣瀹㈡埛鐢诲儚 (ICP)
  targetIndustries Json @default("[]") // 鐩爣琛屼笟
  targetRegions    Json @default("[]") // 鐩爣鍦板尯
  buyerPersonas    Json @default("[]") // 涔板瑙掕壊
  painPoints       Json @default("[]") // 瀹㈡埛鐥涚偣
  buyingTriggers   Json @default("[]") // 璐拱瑙﹀彂鍥犵礌
  exploredRegions  Json @default("[]") // 已探索过的区域记录 [{ region, countries, exploredAt }]

  // AI 鍒嗘瀽鍏冩暟鎹?
  lastAnalyzedAt DateTime?
  analysisSource Json      @default("[]") // 鍒嗘瀽浣跨敤鐨勭礌鏉怚D鍒楄〃
  aiModel        String? // 浣跨敤鐨凙I妯″瀷
  rawAnalysis    String? // AI鍘熷鍒嗘瀽缁撴灉

  // Phase 2 鎵╁睍
  sectionEdits Json @default("{}") // { sectionKey: { content, editedAt, editedBy } }
  evidenceRefs Json @default("{}") // { sectionKey: string[] }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== MODULE 5: ASSET HUB ====================

model AssetFolder {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  parentId    String?
  parent      AssetFolder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children    AssetFolder[] @relation("FolderTree")
  color       String?
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  assets Asset[]

  @@unique([tenantId, name, parentId])
}

model Asset {
  id           String       @id @default(cuid())
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User         @relation(fields: [uploadedById], references: [id])
  folderId     String?
  folder       AssetFolder? @relation(fields: [folderId], references: [id])

  // 鏂囦欢淇℃伅
  originalName String
  storageKey   String
  mimeType     String
  fileSize     BigInt
  extension    String

  // 鍒嗙被
  fileCategory String // video | image | document | audio | other
  purpose      String[] // knowledge | marketing | reference
  tags         String[]

  // 鍐呭
  title       String
  description String?
  metadata    Json    @default("{}")

  // 鐘舵€?
  status    String    @default("uploading") // uploading | active | archived | deleted
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  chunks AssetChunk[]
}

// ==================== ASSET CHUNKS (鏂囨湰鍒嗗潡) ====================

model AssetChunk {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assetId  String
  asset    Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  content    String
  chunkIndex Int
  pageNumber Int?
  charStart  Int?
  charEnd    Int?
  tokenCount Int?

  createdAt DateTime @default(now())

  evidences Evidence[]
}

// ==================== EVIDENCE (璇佹嵁搴? ====================

model Evidence {
  id            String       @id @default(cuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title         String
  content       String
  type          EvidenceType @default(claim)
  sourceLocator Json         @default("{}")
  chunkId       String?
  chunk         AssetChunk?  @relation(fields: [chunkId], references: [id], onDelete: SetNull)
  assetId       String?
  tags          String[]
  status        String       @default("active")
  metadata      Json         @default("{}")
  createdById   String
  createdBy     User         @relation(fields: [createdById], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?
}

// ==================== BRAND GUIDELINES (鍝佺墝瑙勮寖) ====================

model BrandGuideline {
  id        String            @id @default(cuid())
  tenantId  String
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category  GuidelineCategory
  title     String
  content   String
  examples  Json              @default("[]")
  isActive  Boolean           @default(true)
  order     Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

// ==================== ICP & PERSONA (鐢诲儚涓績) ====================

model ICPSegment {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  industry    String?
  companySize String?
  regions     String[]
  description String?
  criteria    Json     @default("{}")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  personas Persona[]
}

model Persona {
  id             String      @id @default(cuid())
  tenantId       String
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  segmentId      String?
  segment        ICPSegment? @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  name           String
  title          String
  seniority      String?
  concerns       String[]
  messagingPrefs Json        @default("{}")
  evidenceRefs   String[]
  order          Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  messagingMatrix MessagingMatrix[]
  contentBriefs   ContentBrief[]
}

model MessagingMatrix {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  personaId    String
  persona      Persona  @relation(fields: [personaId], references: [id], onDelete: Cascade)
  valueProp    String
  message      String
  channel      String?
  evidenceRefs String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ==================== Phase 3: ARTIFACT VERSIONING ====================

model ArtifactVersion {
  id          String         @id @default(cuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entityType  String // "CompanyProfile"|"Evidence"|"BrandGuideline"|"Persona"|"ContentBrief"|"SeoContent"
  entityId    String
  version     Int // 浠?1 鑷
  status      ArtifactStatus @default(draft)
  content     Json // 瀹炰綋瀹屾暣蹇収
  meta        Json           @default("{}") // { changeNote, generatedBy: "ai"|"human", wordCount }
  createdById String
  createdBy   User           @relation(fields: [createdById], references: [id])
  createdAt   DateTime       @default(now())

  comments ArtifactComment[]
  tasks    ArtifactTask[]

  @@unique([entityType, entityId, version])
}

// ==================== Phase 3: CONTENT BRIEF ====================

model ContentBrief {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title           String
  targetPersonaId String?
  targetPersona   Persona?  @relation(fields: [targetPersonaId], references: [id], onDelete: SetNull)
  targetKeywords  String[]
  intent          String // "informational"|"commercial"|"transactional"|"navigational"
  cta             String?
  evidenceIds     String[] // 寮曠敤鐨?Evidence id 鍒楄〃
  notes           String?
  status          String    @default("draft") // "draft"|"ready"|"in_progress"|"done"
  createdById     String
  createdBy       User      @relation(fields: [createdById], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  contentPieces SeoContent[]
}

// ==================== Phase 3: ARTIFACT COLLABORATION ====================

model ArtifactComment {
  id         String            @id @default(cuid())
  tenantId   String
  versionId  String
  version    ArtifactVersion   @relation(fields: [versionId], references: [id], onDelete: Cascade)
  content    String
  authorId   String
  author     User              @relation(fields: [authorId], references: [id])
  parentId   String?
  parent     ArtifactComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies    ArtifactComment[] @relation("CommentReplies")
  resolvedAt DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  // Phase 3 鍗忎綔澹筹細閿氱偣瀹氫綅
  anchorType  String? // "jsonPath"|"textRange"|"blockId"|"rowId"
  anchorValue String? // e.g. "coreProducts[0]", "block-uuid-xxx"
  anchorLabel String? // 浜虹被鍙鏍囩锛屽"鏍稿績浜у搧路绗?椤?

  // 璇勮杞换鍔″叧鑱?
  linkedTask ArtifactTask? @relation("CommentTask")
}

model ArtifactTask {
  id          String          @id @default(cuid())
  tenantId    String
  versionId   String
  version     ArtifactVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  title       String
  assigneeId  String?
  assignee    User?           @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  status      String          @default("open") // "open"|"in_progress"|"done"|"cancelled"
  priority    String          @default("normal") // "urgent"|"normal"|"low"
  dueDate     DateTime?
  createdById String
  createdBy   User            @relation("TaskCreator", fields: [createdById], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Phase 3 鍗忎綔澹筹細鏉ユ簮璇勮鍏宠仈
  sourceCommentId String?          @unique
  sourceComment   ArtifactComment? @relation("CommentTask", fields: [sourceCommentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

// ==================== Phase 3: DECISION CENTER CHAT ====================

model ChatConversation {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String?
  contextSnapshot Json? // debug 鐢細璁板綍鏋勫缓鏃剁殑涓婁笅鏂囨憳瑕?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  messages ChatMessage[]
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // "user"|"assistant"|"system"
  content        String
  references     Json? // [{ evidenceId, title, excerpt }]
  tokens         Int?
  createdAt      DateTime         @default(now())
}

// ==================== MODULE 7: RADAR (鑾峰闆疯揪) ====================

// ==================== ENUMS (Radar) ====================

enum ChannelType {
  TENDER // 鎷涙爣/閲囪喘
  MAPS // 鍦板浘 POI
  DIRECTORY // 琛屼笟鍚嶅綍/鍗忎細
  TRADESHOW // 灞曚細
  HIRING // 鎷涜仒淇″彿
  ECOSYSTEM // 鐢熸€佷紮浼?
  CUSTOM // 鑷畾涔?
}

enum AdapterType {
  API // 瀹樻柟 REST/GraphQL API
  RSS // RSS/Atom feed
  AI_SEARCH // AI + 鎼滅储寮曟搸
  CSV_IMPORT // CSV 瀵煎叆
  MANUAL // 鎵嬪姩褰曞叆
}

enum RadarStoragePolicy {
  ID_ONLY // 鍙瓨 ID锛岃鎯呮寜闇€鎷夊彇
  TTL_CACHE // 缂撳瓨 N 澶╁悗娓呯悊
  SNAPSHOT_IMPORT // 瀵煎叆鏃跺揩鐓ф案涔呭瓨鍌?
}

enum CandidateType {
  COMPANY // 鍏徃
  OPPORTUNITY // 鏈轰細锛堟嫑鏍?椤圭洰锛?
  CONTACT // 鑱旂郴浜?
}

enum CandidateStatus {
  NEW // 鏂板彂鐜?
  REVIEWING // 瀹℃牳涓?
  QUALIFIED // 宸插悎鏍煎寲
  IMPORTED // 宸插鍏ョ嚎绱㈠簱
  EXCLUDED // 宸叉帓闄?
  EXPIRED // 宸茶繃鏈?
  ENRICHING // 绛夊緟 getDetails() 琛ュ叏
}

enum RadarTaskStatus {
