// ==================== й‘ҫеі°о…№й—Ҷз–ҜжҸӘ йҲ«?й’Җгғ©ж”ўйҚҗе‘ӯоҶҗй‘ұж–ҝе§© ====================

enum ContentLinkType {
  KEYWORD_MATCH // йҚҸжҠҪж•ӯз’Үе¶…е°®й–°?
  INDUSTRY_MATCH // зҗӣеұјз¬ҹйҚ–еҪ’еҺӨ
  OUTREACH_EMBED // жҫ¶ж ¬д»Ҳе®“еұҪеҸҶ
  MANUAL // йҺөе¬Әе§©йҚҸе® д»Ҳ
}

model RadarContentLink {
  id       String @id @default(cuid())
  tenantId String

  // йҚҷеұҪжӮңйҚҸе® д»Ҳ
  candidateId String
  candidate   RadarCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  contentId   String
  content     SeoContent     @relation(fields: [contentId], references: [id], onDelete: Cascade)

  // йҚҸе® д»Ҳз»«иҜІзҖ·ж¶“еәЈзІҸй‘ә?
  linkType     ContentLinkType
  matchScore   Float? // йҚ–еҪ’еҺӨжҗҙ?0-100
  matchDetails Json? // { matchedKeywords[], reasons[], matchMethod }

  // жҫ¶ж ¬д»ҲйҗҳиҲөвӮ¬дҪҪжӢ·йҹӘ?
  outreachStatus   String? // pending | sent | opened | replied
  outreachRecordId String? // йҚҸе® д»Ҳ OutreachRecord id

  // йҸҒе ҹзҒүжқ©еҖҹйҮң
  clickCount     Int     @default(0)
  leadGenerated  Boolean @default(false)
  conversionNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([candidateId, contentId])
  @@index([tenantId])
  @@index([contentId])
  @@index([candidateId])
  @@map("radar_content_links")
}

// ==================== GEO йҚ’е——еҪӮжқ©еҖҹйҮң ====================

enum GeoChannel {
  CHATGPT // ChatGPT / ChatGPT Search
  PERPLEXITY // Perplexity AI
  CLAUDE // Claude
  GEMINI // Gemini / Google AI Overviews
  BING_COPILOT // Bing Copilot
  CUSTOM_SITE // зҖ№гҲЎеҹӣйҗҷо„ӮзҸӣз»”?
}

enum CitationStatus {
  PENDING // еҜ°е‘®о—…еЁҙ?
  CITED // е®ёиҢ¶оқҰеҜ®жӣ ж•Ө
  NOT_CITED // йҸҲоҒҮоқҰеҜ®жӣ ж•Ө
  PARTIAL // й–®г„ҘеһҺеҜ®жӣ ж•Ө
  ERROR // еҰ«вӮ¬еЁҙе¬ӘгҒ‘з’җ?
}

model GeoDistributionRecord {
  id       String @id @default(cuid())
  tenantId String

  // йҚҸе® д»ҲйҚҗе‘ӯоҶҗ
  contentId String
  content   SeoContent @relation(fields: [contentId], references: [id], onDelete: Cascade)

  // йҚ’е——еҪӮеЁ“зҠ»дәҫ
  channel       GeoChannel
  channelDetail String? // e.g. "ChatGPT Search", "Google AI Overviews"

  // йҚ’е——еҪӮйҚҗе‘ӯоҶҗи№ҮоӮӨеҸҺ
  distributedVersion String? // йҚ’е——еҪӮйҸғеүҒж®‘ geoVersion и№ҮоӮӨеҸҺй”ӣе қеў 200зҖӣжҘӢзҙҡ
  queryKeywords      String[] // йҗўг„Өз°¬еҰ«вӮ¬еЁҙе¬Әзҙ©йҗўг„§ж®‘йҸҢгғЁоҮ—з’Ү?

  // еҜ®жӣ ж•Өжқ©еҖҹйҮң
  citationStatus  CitationStatus @default(PENDING)
  citationUrl     String? // AI еҜ®жӣҹжҗёеҜ®жӣ ж•ӨйҗЁ?URL
  citationSnippet String? // AI еҜ®жӣҹжҗёеҜ®жӣ ж•ӨйҗЁеӢӯеў–еЁҲ?
  citationScore   Float? // еҜ®жӣ ж•Өз’җг„©еҷәз’ҮеӢ«еһҺ 0-100
  lastCheckedAt   DateTime?

  // еҰ«вӮ¬еЁҙе¬Әе·»йҚҷ?
  checkCount   Int   @default(0)
  checkHistory Json? // [{ checkedAt, status, snippet }]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contentId, channel])
  @@index([tenantId])
  @@index([citationStatus])
  @@map("geo_distribution_records")
}

// ==================== NOTIFICATIONS ====================

model Notification {
