// ==================== 鑾峰闆疯揪 鈫?钀ラ攢鍐呭鑱斿姩 ====================

enum ContentLinkType {
  KEYWORD_MATCH // 鍏抽敭璇嶅尮閰?
  INDUSTRY_MATCH // 琛屼笟鍖归厤
  OUTREACH_EMBED // 澶栬仈宓屽叆
  MANUAL // 鎵嬪姩鍏宠仈
}

model RadarContentLink {
  id       String @id @default(cuid())
  tenantId String

  // 鍙屽悜鍏宠仈
  candidateId String
  candidate   RadarCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  contentId   String
  content     SeoContent     @relation(fields: [contentId], references: [id], onDelete: Cascade)

  // 鍏宠仈绫诲瀷涓庣粏鑺?
  linkType     ContentLinkType
  matchScore   Float? // 鍖归厤搴?0-100
  matchDetails Json? // { matchedKeywords[], reasons[], matchMethod }

  // 澶栬仈鐘舵€佽拷韪?
  outreachStatus   String? // pending | sent | opened | replied
  outreachRecordId String? // 鍏宠仈 OutreachRecord id

  // 鏁堟灉杩借釜
  clickCount     Int     @default(0)
  leadGenerated  Boolean @default(false)
  conversionNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([candidateId, contentId])
  @@index([tenantId])
  @@index([contentId])
  @@index([candidateId])
  @@map("radar_content_links")
}

// ==================== GEO 鍒嗗彂杩借釜 ====================

enum GeoChannel {
  CHATGPT // ChatGPT / ChatGPT Search
  PERPLEXITY // Perplexity AI
  CLAUDE // Claude
  GEMINI // Gemini / Google AI Overviews
  BING_COPILOT // Bing Copilot
  CUSTOM_SITE // 瀹㈡埛鐙珛绔?
}

enum CitationStatus {
  PENDING // 寰呮娴?
  CITED // 宸茶寮曠敤
  NOT_CITED // 鏈寮曠敤
  PARTIAL // 閮ㄥ垎寮曠敤
  ERROR // 妫€娴嬪け璐?
}

model GeoDistributionRecord {
  id       String @id @default(cuid())
  tenantId String

  // 鍏宠仈鍐呭
  contentId String
  content   SeoContent @relation(fields: [contentId], references: [id], onDelete: Cascade)

  // 鍒嗗彂娓犻亾
  channel       GeoChannel
  channelDetail String? // e.g. "ChatGPT Search", "Google AI Overviews"

  // 鍒嗗彂鍐呭蹇収
  distributedVersion String? // 鍒嗗彂鏃剁殑 geoVersion 蹇収锛堝墠200瀛楋級
  queryKeywords      String[] // 鐢ㄤ簬妫€娴嬪紩鐢ㄧ殑鏌ヨ璇?

  // 寮曠敤杩借釜
  citationStatus  CitationStatus @default(PENDING)
  citationUrl     String? // AI 寮曟搸寮曠敤鐨?URL
  citationSnippet String? // AI 寮曟搸寮曠敤鐨勭墖娈?
  citationScore   Float? // 寮曠敤璐ㄩ噺璇勫垎 0-100
  lastCheckedAt   DateTime?

  // 妫€娴嬪巻鍙?
  checkCount   Int   @default(0)
  checkHistory Json? // [{ checkedAt, status, snippet }]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contentId, channel])
  @@index([tenantId])
  @@index([citationStatus])
  @@map("geo_distribution_records")
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type      String // "tier_a_lead" | "geo_citation" | "publish_failed" | "system"
  title     String
  body      String
