  // 鑱旂郴浜哄瓧娈碉紙candidateType=CONTACT锛?
  contactRole       String?
  linkedInUrl       String? // 鍏徃 LinkedIn 椤礬uff08Exa 涓板瘜鍖栧啓鍏uff09
  linkedCandidateId String? // 鍏宠仈鍒板摢涓叕鍙稿€欓€?

  // ICP 鍖归厤锛堟牳蹇冿級
  matchScore   Float?
  matchExplain Json? // { rules: [...], reasons: [...], query, channel }

  // AI 澶勭悊
  aiSummary   String?
  aiRelevance Json? // { score, reasons[], matchedKeywords[] }

  // 鐘舵€?
  status        CandidateStatus @default(NEW)
  qualifyTier   String? // A | B | C | excluded
  qualifyReason String?
  qualifiedAt   DateTime?
  qualifiedBy   String?

  // 瀵煎叆杩借釜
  importedToType String? // ProspectCompany | Opportunity
  importedToId   String?
  importedAt     DateTime?
  importedBy     String?

  // 鎸佺画鎵弿鍏宠仈
  profileId   String? // 瑙﹀彂璇ュ€欓€夌殑 SearchProfile
  publishedAt DateTime? // 鎷涙爣鍙戝竷鏃堕棿锛堜粠 source 鑾峰彇锛?
  enrichedAt  DateTime? // 璇︽儏琛ュ叏瀹屾垚鏃堕棿

  // TTL 绛栫暐
  rawData  Json?
  expireAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contentLinks RadarContentLink[] // 鑾峰闆疯揪鍐呭鑱斿姩

  @@unique([sourceId, externalId])
