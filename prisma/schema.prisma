// ==================== API璋冪敤鏃ュ織锛堟垚鏈拷韪級 ====================

model ApiCallLog {
  id String @id @default(cuid())

  // 鏈嶅姟淇℃伅
  service   String // google_places, apollo, skrapp, hunter, brave_search
  operation String // search, enrich, verify

  // 鎴愭湰
  cost    Float @default(0) // USD
  credits Int   @default(0) // 绉垎锛堝彲閫夛級

  // 缁撴灉
