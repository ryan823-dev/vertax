generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== TENANT & AUTH ====================

model Tenant {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  domain      String?
  plan        String    @default("free")
  status      String    @default("active")
  settings    Json      @default("{}")
  emailConfig Json? // 邮件配置：平台Key/自定义Key、发件域名等
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  users              User[]
  products           Product[]
  seoContents        SeoContent[]
  seoAudits          SeoAudit[]
  socialPosts        SocialPost[]
  socialAccounts     SocialAccount[]
  leads              Lead[]
  campaigns          Campaign[]
  categories         ContentCategory[]
  websiteConfigs     WebsiteConfig[]
  activities         Activity[]
  notifications      Notification[]
  assetFolders       AssetFolder[]
  assets             Asset[]
  apiKeys            ApiKey[]
  companyProfile     CompanyProfile?
  assetChunks        AssetChunk[]
  evidences          Evidence[]
  brandGuidelines    BrandGuideline[]
  icpSegments        ICPSegment[]
  personas           Persona[]
  messagingMatrices  MessagingMatrix[]
  // Phase 3
  artifactVersions   ArtifactVersion[]
  contentBriefs      ContentBrief[]
  chatConversations  ChatConversation[]
  prospectCompanies  ProspectCompany[]
  radarDailySnapshots RadarDailySnapshot[]
  // Web crawl queue
  crawlQueues        CrawlQueue[]
  // Asset processing queue
  assetProcessQueues AssetProcessQueue[]
}

model WebsiteConfig {
  id              String  @id @default(cuid())
  tenantId        String
  tenant          Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  siteName        String? // 目标站名称（多站区分）
  url             String?
  apiKey          String?
  publishEndpoint String?
  seoDefaults     Json    @default("{}")

  // === Publishing Pipeline 扩展 ===
  siteType             String  @default("supabase") // supabase | nextjs | wordpress | rest
  supabaseUrl          String? // [supabase] e.g. "https://xxx.supabase.co"
  functionName         String? // [supabase] e.g. "receive-content-push"
  webhookUrl           String? // [nextjs | rest] 客户站接收 endpoint
  wpUrl                String? // [wordpress] WP 站点根 URL
  wpUsername           String? // [wordpress] WP 用户名
  wpPassword           String? // [wordpress] Application Password
  pushSecret           String? // 共享密钥（HMAC签名 / Bearer token）
  customHeaders        Json? // 自定义请求头（rest/nextjs 用）
  fieldMapping         Json    @default("{}") // Vertax → 目标站字段映射
  approvalTimeoutHours Int     @default(24)
  isActive             Boolean @default(true)

  pushRecords PushRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// ==================== CONTENT PUSH PIPELINE ====================

enum PushStatus {
  PENDING // 已推送，等待客户站点审核
  CONFIRMED // 瀹㈡埛绔欑偣宸茬‘璁ゅ彂甯?
  TIMEOUT // 瓒呮椂鏈‘璁?
  FAILED // 推送失败
  ESCALATED // 已升级到运营处理
}

model PushRecord {
  id       String @id @default(cuid())
  tenantId String

  // 关联内容
  contentId String // SeoContent.id
  content   SeoContent @relation(fields: [contentId], references: [id], onDelete: Cascade)

  // 目标站点
  websiteConfigId String
  websiteConfig   WebsiteConfig @relation(fields: [websiteConfigId], references: [id], onDelete: Cascade)

  // 推送状态
  status     PushStatus @default(PENDING)
  remoteId   String? // 目标站点返回的记录 ID
  remoteSlug String? // 目标站点的 slug
  targetUrl  String? // 目标站点上的完整 URL

  // 字段快照（推送时的映射结果）
  pushPayload     Json? // 实际发送的 payload 快照
  contentVersion  Int? // 推送时对应的 SeoContent.version
  contentSnapshot Json? // { title, slug, excerpt, keywords } 蹇収

  // 时间追踪
  pushedAt    DateTime  @default(now())
  timeoutAt   DateTime // pushedAt + approvalTimeoutHours
  confirmedAt DateTime?
  escalatedAt DateTime?

  // 错误处理
  retryCount Int     @default(0)
  lastError  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contentId, websiteConfigId]) // 每个内容每个站点只有一条推送记录
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?
  tenantId      String?
  tenant        Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roleId        String
  role          Role      @relation(fields: [roleId], references: [id])
  locale        String    @default("zh-CN")
  timezone      String    @default("Asia/Shanghai")
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  accounts          Account[]
  sessions          Session[]
  seoContents       SeoContent[]
  seoAudits         SeoAudit[]
  socialPosts       SocialPost[]
  ownedLeads        Lead[]
  activities        Activity[]
  assets            Asset[]
  evidences         Evidence[]
  // Phase 3
  artifactVersions  ArtifactVersion[]
  contentBriefs     ContentBrief[]
  artifactComments  ArtifactComment[]
  tasksCreated      ArtifactTask[]     @relation("TaskCreator")
  tasksAssigned     ArtifactTask[]     @relation("TaskAssignee")
  chatConversations ChatConversation[]
}

model Role {
  id           String   @id @default(cuid())
  name         String   @unique
  displayName  String
  permissions  Json
  isSystemRole Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users User[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ApiKey {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  key         String    @unique
  permissions String[]  @default(["assets:write"])
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ==================== MODULE 1: PRODUCTS ====================

model Product {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sku             String?
  name            String
  slug            String
  description     String?
  detailedContent String?
  status          String    @default("draft")
  publishedAt     DateTime?
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  images     ProductImage[]
  specs      ProductSpec[]
  categories ProductCategory[]

  @@unique([tenantId, slug])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  altText   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model ProductSpec {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  key       String
  value     String
  unit      String?
  order     Int     @default(0)
}

model ProductCategory {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String

  @@unique([productId, name])
}

// ==================== MODULE 2: SEO & GEO CONTENT ====================

model SeoAudit {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  targetUrl     String
  status        String    @default("pending")
  progress      Int       @default(0)
  currentStep   String?
  scores        Json      @default("{}")
  findings      Json      @default("[]")
  aiSummary     String?
  crawlErrors   Json      @default("[]")
  pagesCrawled  Int       @default(0)
  crawlDuration Int?
  createdAt     DateTime  @default(now())
  completedAt   DateTime?
}

model ContentCategory {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  description String?
  icon        String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contents SeoContent[]

  @@unique([tenantId, slug])
}

model SeoContent {
  id              String          @id @default(cuid())
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId      String
  category        ContentCategory @relation(fields: [categoryId], references: [id])
  authorId        String
  author          User            @relation(fields: [authorId], references: [id])
  title           String
  slug            String
  excerpt         String?
  content         String
  metaTitle       String?
  metaDescription String?
  keywords        String[]
  featuredImage   String?
  status          String          @default("draft")
  publishedAt     DateTime?
  scheduledAt     DateTime?
  version         Int             @default(1) // 内容版本号，每次保存自动 +1
  aiMetadata      Json            @default("{}")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  // Phase 3 扩展
  briefId          String?
  brief            ContentBrief?           @relation(fields: [briefId], references: [id], onDelete: SetNull)
  outline          Json? // { sections: [{ heading, keyPoints }] }
  evidenceRefs     String[] // 引用的 Evidence id
  schemaJson       Json? // Schema.org 结构化数据(FAQPage JSON-LD)
  geoVersion       String? // GEO-optimized short version (300-500 words, for AI citation)

  // Auto-publish grace period (24h window for AI-generated content)
  autoPublishAt    DateTime? // Non-null = awaiting publish, cron will auto-publish when reached
  generatedBy      String? // "ai" | "human" | null, marks content origin

  pushRecords      PushRecord[] // 推送记录
  contentLinks     RadarContentLink[] // 获客雷达内容联动
  geoDistributions GeoDistributionRecord[] // GEO 分发追踪

  @@unique([tenantId, slug])
  @@index([status, autoPublishAt]) // For auto-publish cron query
}

// ==================== MODULE 3: SOCIAL MEDIA ====================

model SocialAccount {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  platform     String
  accountName  String
  accountId    String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  metadata     Json      @default("{}")
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([tenantId, platform, accountId])
}

model SocialPost {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  authorId     String
  author       User      @relation(fields: [authorId], references: [id])
  title        String?
  status       String    @default("draft")
  scheduledAt  DateTime?
  publishedAt  DateTime?
  autoEngage   Boolean   @default(false)
  engageConfig Json      @default("{}")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  versions PostVersion[]
}

model PostVersion {
  id              String     @id @default(cuid())
  postId          String
  post            SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  platform        String
  content         String
  media           String[]
  platformPostId  String?
  publishedAt     DateTime?
  error           String?
  publishAttempts Int        @default(0)
  metrics         Json       @default("{}")
}

// ==================== MODULE 4: AI LEAD GENERATION ====================

model Lead {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ownerId         String
  owner           User      @relation(fields: [ownerId], references: [id])
  companyName     String
  contactName     String?
  email           String?
  phone           String?
  website         String?
  country         String?
  city            String?
  industry        String?
  companySize     String?
  status          String    @default("new")
  priority        String    @default("medium")
  researchData    Json      @default("{}")
  notes           String?
  lastContactedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  campaigns CampaignLead[]
}

model Campaign {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  emailTemplate  String
  subject        String
  status         String    @default("draft")
  scheduledStart DateTime?
  scheduledEnd   DateTime?
  metrics        Json      @default("{}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  leads CampaignLead[]
}

model CampaignLead {
  id                  String    @id @default(cuid())
  campaignId          String
  campaign            Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  leadId              String
  lead                Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  status              String    @default("pending")
  sentAt              DateTime?
  openedAt            DateTime?
  repliedAt           DateTime?
  personalizedContent String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([campaignId, leadId])
}

// ==================== SYSTEM ====================

model Activity {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String
  entityType String
  entityId   String
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  // Phase 3 扩展
  eventCategory String? // "knowledge"|"marketing"|"review"|"chat"|"system"
  severity      String? // "info"|"warn"|"error"
  context       Json? // { versionId, briefId, previousStatus, ... }
}

// ==================== MODULE 6: KNOWLEDGE ENGINE ====================

// ==================== ENUMS (Knowledge) ====================

enum EvidenceType {
  claim
  statistic
  testimonial
  case_study
  certification
}

enum GuidelineCategory {
  tone
  terminology
  visual
  messaging
}

// ==================== Phase 3: Artifact Versioning ====================

enum ArtifactStatus {
  draft
  in_review
  client_feedback
  revised
  approved
  published // UI隐藏，后续启用
  archived
}

model CompanyProfile {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // 企业基本信息（AI提炼）
  companyName  String?
  companyIntro String?

  // 核心能力画像
  coreProducts    Json @default("[]") // 核心产品/服务能力
  techAdvantages  Json @default("[]") // 技术优势
  scenarios       Json @default("[]") // 适用场景/行业
  differentiators Json @default("[]") // 差异化卖点

  // 目标客户画像 (ICP)
  targetIndustries Json @default("[]") // 目标行业
  targetRegions    Json @default("[]") // 目标地区
  buyerPersonas    Json @default("[]") // 买家角色
  painPoints       Json @default("[]") // 客户痛点
  buyingTriggers   Json @default("[]") // 购买触发因素
  exploredRegions  Json @default("[]") // 已探索过的区域记录 [{ region, countries, exploredAt }]

  // AI 分析元数据
  lastAnalyzedAt DateTime?
  analysisSource Json      @default("[]") // 分析使用的素材ID列表
  aiModel        String? // 使用的AI模型
  rawAnalysis    String? // AI原始分析结果

  // Phase 2 扩展
  sectionEdits Json @default("{}") // { sectionKey: { content, editedAt, editedBy } }
  evidenceRefs Json @default("{}") // { sectionKey: string[] }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== MODULE 5: ASSET HUB ====================

model AssetFolder {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  parentId    String?
  parent      AssetFolder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children    AssetFolder[] @relation("FolderTree")
  color       String?
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  assets Asset[]

  @@unique([tenantId, name, parentId])
}

model Asset {
  id           String       @id @default(cuid())
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User         @relation(fields: [uploadedById], references: [id])
  folderId     String?
  folder       AssetFolder? @relation(fields: [folderId], references: [id])

  // 文件信息
  originalName String
  storageKey   String
  mimeType     String
  fileSize     BigInt
  extension    String

  // 分类
  fileCategory String // video | image | document | audio | other
  purpose      String[] // knowledge | marketing | reference
  tags         String[]

  // 内容
  title       String
  description String?
  metadata    Json    @default("{}")

  // 状态
  status    String    @default("uploading") // uploading | active | archived | deleted
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  chunks AssetChunk[]
}

// ==================== ASSET CHUNKS (文本分块) ====================

model AssetChunk {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assetId  String
  asset    Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  content    String
  chunkIndex Int
  pageNumber Int?
  charStart  Int?
  charEnd    Int?
  tokenCount Int?

  createdAt DateTime @default(now())

  evidences Evidence[]
}

// ==================== EVIDENCE (证据库) ====================

model Evidence {
  id            String       @id @default(cuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title         String
  content       String
  type          EvidenceType @default(claim)
  sourceLocator Json         @default("{}")
  chunkId       String?
  chunk         AssetChunk?  @relation(fields: [chunkId], references: [id], onDelete: SetNull)
  assetId       String?
  tags          String[]
  status        String       @default("active")
  metadata      Json         @default("{}")
  createdById   String
  createdBy     User         @relation(fields: [createdById], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?
}

// ==================== BRAND GUIDELINES (品牌规范) ====================

model BrandGuideline {
  id        String            @id @default(cuid())
  tenantId  String
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category  GuidelineCategory
  title     String
  content   String
  examples  Json              @default("[]")
  isActive  Boolean           @default(true)
  order     Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

// ==================== ICP & PERSONA (画像中心) ====================

model ICPSegment {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  industry    String?
  companySize String?
  regions     String[]
  description String?
  criteria    Json     @default("{}")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  personas Persona[]
}

model Persona {
  id             String      @id @default(cuid())
  tenantId       String
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  segmentId      String?
  segment        ICPSegment? @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  name           String
  title          String
  seniority      String?
  concerns       String[]
  messagingPrefs Json        @default("{}")
  evidenceRefs   String[]
  order          Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  messagingMatrix MessagingMatrix[]
  contentBriefs   ContentBrief[]
}

model MessagingMatrix {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  personaId    String
  persona      Persona  @relation(fields: [personaId], references: [id], onDelete: Cascade)
  valueProp    String
  message      String
  channel      String?
  evidenceRefs String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ==================== Phase 3: ARTIFACT VERSIONING ====================

model ArtifactVersion {
  id          String         @id @default(cuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entityType  String // "CompanyProfile"|"Evidence"|"BrandGuideline"|"Persona"|"ContentBrief"|"SeoContent"
  entityId    String
  version     Int // 从 1 自增
  status      ArtifactStatus @default(draft)
  content     Json // 实体完整快照
  meta        Json           @default("{}") // { changeNote, generatedBy: "ai"|"human", wordCount }
  createdById String
  createdBy   User           @relation(fields: [createdById], references: [id])
  createdAt   DateTime       @default(now())

  comments ArtifactComment[]
  tasks    ArtifactTask[]

  @@unique([entityType, entityId, version])
}

// ==================== Phase 3: CONTENT BRIEF ====================

model ContentBrief {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title           String
  targetPersonaId String?
  targetPersona   Persona?  @relation(fields: [targetPersonaId], references: [id], onDelete: SetNull)
  targetKeywords  String[]
  intent          String // "informational"|"commercial"|"transactional"|"navigational"
  cta             String?
  evidenceIds     String[] // 引用的 Evidence id 列表
  notes           String?
  status          String    @default("draft") // "draft"|"ready"|"in_progress"|"done"
  createdById     String
  createdBy       User      @relation(fields: [createdById], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  contentPieces SeoContent[]
}

// ==================== Phase 3: ARTIFACT COLLABORATION ====================

model ArtifactComment {
  id         String            @id @default(cuid())
  tenantId   String
  versionId  String
  version    ArtifactVersion   @relation(fields: [versionId], references: [id], onDelete: Cascade)
  content    String
  authorId   String
  author     User              @relation(fields: [authorId], references: [id])
  parentId   String?
  parent     ArtifactComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies    ArtifactComment[] @relation("CommentReplies")
  resolvedAt DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  // Phase 3 协作：锚点定位
  anchorType  String? // "jsonPath"|"textRange"|"blockId"|"rowId"
  anchorValue String? // e.g. "coreProducts[0]", "block-uuid-xxx"
  anchorLabel String? // 人类可读标签，如"核心产品·第1项"

  // 评论转任务关联
  linkedTask ArtifactTask? @relation("CommentTask")
}

model ArtifactTask {
  id          String          @id @default(cuid())
  tenantId    String
  versionId   String
  version     ArtifactVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  title       String
  assigneeId  String?
  assignee    User?           @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  status      String          @default("open") // "open"|"in_progress"|"done"|"cancelled"
  priority    String          @default("normal") // "urgent"|"normal"|"low"
  dueDate     DateTime?
  createdById String
  createdBy   User            @relation("TaskCreator", fields: [createdById], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Phase 3 协作：来源评论关联
  sourceCommentId String?          @unique
  sourceComment   ArtifactComment? @relation("CommentTask", fields: [sourceCommentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

// ==================== Phase 3: DECISION CENTER CHAT ====================

model ChatConversation {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String?
  contextSnapshot Json? // debug 用：记录构建时的上下文摘要
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  messages ChatMessage[]
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // "user"|"assistant"|"system"
  content        String
  references     Json? // [{ evidenceId, title, excerpt }]
  payload        Json?
  tokens         Int?
  createdAt      DateTime         @default(now())
}

// ==================== MODULE 7: RADAR (获客雷达) ====================

// ==================== ENUMS (Radar) ====================

enum ChannelType {
  TENDER // 招标/采购
  MAPS // 地图 POI
  DIRECTORY // 行业名录/协会
  TRADESHOW // 展会
  HIRING // 招聘信号
  ECOSYSTEM // 生态伙伴
  CUSTOM // 自定义
}

enum AdapterType {
  API // 官方 REST/GraphQL API
  RSS // RSS/Atom feed
  AI_SEARCH // AI + 搜索引擎
  CSV_IMPORT // CSV 导入
  MANUAL // 手动录入
}

enum RadarStoragePolicy {
  ID_ONLY // 只存 ID，详情按需拉取
  TTL_CACHE // 缓存 N 天后清理
  SNAPSHOT_IMPORT // 导入时快照永久存储
}

enum CandidateType {
  COMPANY // 公司
  OPPORTUNITY // 机会（招标/项目）
  CONTACT // 联系人
}

enum CandidateStatus {
  NEW // 新发现
  REVIEWING // 审核中
  QUALIFIED // 已合格化
  IMPORTED // 已导入线索库
  EXCLUDED // 已排除
  EXPIRED // 已过期
  ENRICHING // 等待 getDetails() 补全
}

enum RadarTaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum OpportunityStage {
  IDENTIFIED // 已识别
  QUALIFYING // 资格评估中
  PURSUING // 跟进中
  PROPOSAL // 已提案
  NEGOTIATION // 谈判中
  WON // 赢单
  LOST // 丢单
}

// ==================== 数据源目录====================

model RadarSource {
  id       String  @id @default(cuid())
  tenantId String? // null = 系统级公共源

  // 分类
  channelType ChannelType

  // 基础信息
  name        String
  code        String  @unique
  description String?
  logoUrl     String?
  websiteUrl  String?

  // 覆盖范围
  countries String[] // ISO codes, 空 = 全球
  regions   String[] // EU | LATAM | MENA | APAC 等

  // 接入配置
  adapterType   AdapterType
  adapterConfig Json        @default("{}") // API endpoint, auth, field mapping 等

  // 合规与策略
  isOfficial          Boolean            @default(false) // 是否官方源
  requiresAuth        Boolean            @default(false)
  termsUrl            String?
  storagePolicy       RadarStoragePolicy @default(TTL_CACHE)
  ttlDays             Int                @default(90)
  attributionRequired Boolean            @default(true)

  // 速率限制
  rateLimit Json @default("{}") // { requests, windowMs }

  // 状态
  isEnabled  Boolean   @default(true)
  lastSyncAt DateTime?
  syncStats  Json? // { totalFetched, lastError, avgResponseTime }

  // 关系
  candidates RadarCandidate[]
  tasks      RadarTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== 发现任务 ====================

model RadarTask {
  id       String @id @default(cuid())
  tenantId String

  // 任务配置
  name     String?
  sourceId String
  source   RadarSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  // 画像引用（可追溯）
  targetingRef  Json? // { segmentId?, personaId?, specVersionId? }
  channelMapRef String? // 引用 ArtifactVersion id

  // 查询计划
  queryConfig Json // 搜索参数：keywords, categories, regions, dateRange

  // 执行状态
  status      RadarTaskStatus @default(PENDING)
  startedAt   DateTime?
  completedAt DateTime?
  cancelToken String?

  // 统计
  stats        Json? // { fetched, new, duplicate, errors, duration }
  errorMessage String?

  // 触发方式
  triggeredBy  String // userId | "scheduler" | "manual"
  scheduleRule String? // cron expression for recurring

  // 关系
  candidates RadarCandidate[]

  createdAt DateTime @default(now())
}

// ==================== 统一候选池 ====================

model RadarCandidate {
  id       String @id @default(cuid())
  tenantId String

  // 来源杩芥函锛堝繀椤伙級
  sourceId String
  source   RadarSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  taskId   String?
  task     RadarTask?  @relation(fields: [taskId], references: [id], onDelete: SetNull)

  // 候选类型
  candidateType CandidateType

  // 外部标识
  externalId String // place_id, notice_id, etc.
  sourceUrl  String // 蹇呴』鏈夛紝鐢ㄤ簬杩芥函

  // 通用字段
  displayName String
  description String?

  // 公司字段（candidateType=COMPANY）
  website     String?
  phone       String?
  email       String?
  address     String?
  country     String?
  city        String?
  industry    String?
  companySize String?

  // 机会字段（candidateType=OPPORTUNITY，即招标）
  deadline       DateTime?
  estimatedValue Float?
  currency       String?
  buyerName      String?
  buyerCountry   String?
  buyerType      String? // government | enterprise | ngo | international_org
  categoryCode   String? // CPV / UNSPSC
  categoryName   String?

  // 联系人字段（candidateType=CONTACT）
  contactRole       String?
  linkedInUrl       String? // 公司 LinkedIn 页（Exa 丰富化写入）
  linkedCandidateId String? // 关联到哪个公司候选

  // ICP 匹配（核心）
  matchScore   Float?
  matchExplain Json? // { rules: [...], reasons: [...], query, channel }

  // AI 处理
  aiSummary   String?
  aiRelevance Json? // { score, reasons[], matchedKeywords[] }

  // 状态
  status        CandidateStatus @default(NEW)
  qualifyTier   String? // A | B | C | excluded
  qualifyReason String?
  qualifiedAt   DateTime?
  qualifiedBy   String?

  // 导入追踪
  importedToType String? // ProspectCompany | Opportunity
  importedToId   String?
  importedAt     DateTime?
  importedBy     String?

  // 持续扫描关联
  profileId   String? // 触发该候选的 SearchProfile
  publishedAt DateTime? // 招标发布时间（从 source 获取）
  enrichedAt  DateTime? // 详情补全完成时间

  // TTL 策略
  rawData  Json?
  expireAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contentLinks RadarContentLink[] // 获客雷达内容联动

  @@unique([sourceId, externalId])
}

// ==================== 正式线索公司 ====================

model ProspectCompany {
  id       String @id @default(cuid())
  tenantId String

  // 公司信息
  name        String
  website     String?
  phone       String?
  email       String?
  address     String?
  country     String?
  city        String?
  industry    String?
  companySize String?
    description String?

  // AI 评估结论
  matchReasons      Json? // 匹配理由列表
  approachAngle     String?

  enrichmentStatus String? // pending | in_progress | completed | failed
  lastEnrichedAt   DateTime?
  tenant Tenant @relation(fields: [tenantId], references: [id])
  outreachArtifacts Json? // 持久化外联方案 { email: { subject, body }, whatsapp: { message }, ... }


  // 分类与标签
  tier String? // A | B | C
  tags String[]

  // 来源杩芥函
  sourceType        String? // tender | maps | directory | tradeshow | hiring | manual
  sourceCandidateId String? // 来自哪个候选
  sourceUrl         String?

  // 跟进状态
  status          String    @default("new") // new | contacted | qualified | converted | lost
  assignedTo      String?
  lastContactedAt DateTime?
  nextActionDate  DateTime?
  notes           String?

  // 关系
  contacts      ProspectContact[]
  opportunities Opportunity[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

// ==================== 正式联系人====================

model ProspectContact {
  id       String @id @default(cuid())
  tenantId String

  // 关联公司
  companyId String?
  company   ProspectCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  // 联系人信息
  name        String
  email       String?
  phone       String?
  role        String?
  department  String?
  seniority   String? // C-level | VP | Director | Manager | Staff
  linkedInUrl String?

  // 来源
  sourceCandidateId String?
  sourceUrl         String?

  // 状态
  status String  @default("new")
  notes  String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

// ==================== 正式机会（招标转化后）====================

model Opportunity {
  id       String @id @default(cuid())
  tenantId String

  // 关联公司
  companyId String?
  company   ProspectCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  // 来源
  sourceType        String // tender | project | referral | inbound
  sourceCandidateId String?
  sourceUrl         String?

  // 核心信息
  title       String
  description String?

  // 时间与金额
  deadline       DateTime?
  estimatedValue Float?
  currency       String?

  // 分类
  categoryCode String?
  categoryName String?

  // 阶段管理
  stage       OpportunityStage @default(IDENTIFIED)
  probability Int? // 0-100
  lostReason  String?
  wonAt       DateTime?
  lostAt      DateTime?

  // 跟进
  assignedTo     String?
  nextAction     String?
  nextActionDate DateTime?
  notes          String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

// ==================== 搜索配置（定时监控） ====================

model RadarSearchProfile {
  id       String @id @default(cuid())
  tenantId String

  name        String
  description String?

  // 关联画像
  segmentId String? // 关联 ICPSegment
  personaId String? // 关联 Persona

  // 搜索配置
  keywords         Json  @default("{}") // { en: [], zh: [], es: [], ar: [] }
  negativeKeywords Json? // 排除词

  // 目标区域
  targetCountries String[]
  targetRegions   String[]

  // 行业/分类过滤
  industryCodes   String[]
  categoryFilters String[] // CPV/UNSPSC codes

  // 渠道配置
  enabledChannels ChannelType[]
  sourceIds       String[] // 指定的 source ids

  // 调度
  isActive     Boolean   @default(true)
  scheduleRule String    @default("0 6 * * *") // 默认每天早6点
  lastRunAt    DateTime?

  // === 持续扫描引擎 ===
  nextRunAt      DateTime? // 预计算下次运行时间（索引查询）
  lockToken      String? // 乐观锁 UUID
  lockedAt       DateTime? // 锁定时间（5分钟超时释放）
  lockedBy       String? // Vercel 实例标识
  maxRunSeconds  Int       @default(45) // 单次扫描预算（留15s给60s timeout）
  autoQualify    Boolean   @default(true) // 自动触发 AI 合格化
  autoEnrich     Boolean   @default(false) // 自动触发详情补全
  runStats       Json? // { totalRuns, totalNew, lastError, avgDurationMs }
  exclusionRules Json? // 从 rejected 反向学习的排除词

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== 扫描游标（持续增量） ====================

model RadarScanCursor {
  id        String @id @default(cuid())
  profileId String
  sourceId  String

  // 游标状态
  cursorState Json // { nextPage, nextPageToken, since, queryIndex, exhausted }

  // 统计
  lastScanAt   DateTime?
  scanCount    Int       @default(0)
  totalFetched Int       @default(0)
  totalNew     Int       @default(0)
  lastError    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([profileId, sourceId])
}

// ==================== 意图信号追踪 ====================

model IntentSignal {
  id       String @id @default(cuid())
  tenantId String

  // 关联实体
  candidateId String? // 关联 RadarCandidate
  companyId   String? // 关联 ProspectCompany
  contactId   String? // 关联 ProspectContact

  // 信号类型
  signalType String // email_open, email_click, website_visit, pricing_view, demo_request

  // 信号强度
  intensity Float @default(1.0) // 0.0 - 1.0
  score     Int   @default(0) // 计算后的意图分数

  // 信号详情
  metadata  Json? // { emailId, link, page, duration, ip, userAgent }
  ipAddress String?
  userAgent String?
  page      String? // 访问的页面
  referrer  String? // 来源页面

  // 时间戳
  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@map("intent_signals")
}

// ==================== Webhook集成 ====================

model WebhookConfig {
  id       String @id @default(cuid())
  tenantId String

  // Webhook配置
  name     String
  url      String
  method   String  @default("POST") // POST, PUT, PATCH
  headers  Json? // 自定义请求头
  authType String  @default("none") // none, basic, bearer
  secret   String? // 签名密钥（用于验证）

  // 触发事件
  events String[] // candidate_qualified, candidate_imported, email_sent, etc.

  // 执行配置
  isActive   Boolean @default(true)
  retryCount Int     @default(3)
  timeout    Int     @default(5000) // 毫秒

  // 元数据
  lastTriggeredAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  logs WebhookLog[]

  @@map("webhook_configs")
}

model WebhookLog {
  id        String @id @default(cuid())
  tenantId  String
  webhookId String

  // 触发事件
  event   String
  payload Json?

  // 执行结果
  success       Boolean
  statusCode    Int?
  response      String? // JSON响应
  error         String?
  executionTime Int // 毫秒
  retryAttempt  Int     @default(0)

  // 时间戳
  createdAt DateTime @default(now())

  webhook WebhookConfig @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@map("webhook_logs")
}

// ==================== API调用日志（成本追踪） ====================

model ApiCallLog {
  id String @id @default(cuid())

  // 服务信息
  service   String // google_places, apollo, skrapp, hunter, brave_search
  operation String // search, enrich, verify

  // 成本
  cost    Float @default(0) // USD
  credits Int   @default(0) // 积分（可选）

  // 结果
  success   Boolean @default(true)
  errorCode String?
  metadata  Json? // { query, resultCount, duration }

  // 时间戳
  createdAt DateTime @default(now())

  @@map("api_call_logs")
}

// ==================== 统一API密钥管理（Tower后台）====================

model ApiKeyConfig {
  id String @id @default(cuid())

  // 服务名称
  service String @unique // google_places, apollo, skrapp, hunter, brave_search, firecrawl, tavily, exa

  // 分类
  category String @default("other") // AI Provider, 搜索 API, 企业数据, 政府采购

  // 密钥（加密存储）
  apiKey    String?
  apiSecret String? // 部分服务需要两个密钥

  // 状态
  isEnabled  Boolean   @default(true)
  lastUsedAt DateTime?

  // 配额追踪
  monthlyLimit Int? // 月度调用上限
  currentUsage Int       @default(0) // 当前用量
  usageResetAt DateTime? // 用量重置时间

  // 元数据
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isEnabled])
  @@index([category])
  @@map("api_key_configs")
}

// ==================== 邮件附件模板 ====================

model AttachmentTemplate {
  id          String   @id @default(cuid())
  tenantId    String

  // 模板信息
  name        String   // 显示名称
  filename    String   // 实际文件名
  contentType String   // MIME类型
  storageKey  String   // OSS 存储路径
  size        Int      // 文件大小(bytes)

  // 分类
  category    String   @default("other") // catalog, brochure, presentation, other
  industry    String?  // 可选：特定行业
  isDefault   Boolean  @default(false)   // 默认附件

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, isDefault])
  @@index([tenantId, category])
  @@map("attachment_templates")
}

// ==================== 外联邮件记录 ====================


model OutreachRecord {
  id       String @id @default(cuid())
  tenantId String

  // 关联候选
  candidateId String?
  profileId   String? // RadarSearchProfile

  // 收件人信息
  toEmail String
  toName  String?

  // 邮件内容
  subject  String
  bodyText String?
  bodyHtml String?

  // 渠道 & 发送状态
  channel   String  @default("email") // email, linkedin, whatsapp, phone
  messageId String? @unique // Resend message ID
  status    String  @default("pending") // pending, sent, delivered, opened, clicked, bounced, failed, draft_copied, manual_sent

  // 追踪数据
  sentAt      DateTime?
  deliveredAt DateTime?
  openedAt    DateTime?
  clickedAt   DateTime?
  repliedAt   DateTime?

  // 通话结果 (phone channel)
  callResult  String? // connected, no_answer, voicemail, meeting_booked, not_interested, callback

  // 错误信息
  error String?

  // 元数据
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("outreach_records")
}

// ==================== 邮件外联序列 ====================

model SequenceInstance {
  id       String @id @default(cuid())
  tenantId String

  // 序列信息
  sequenceName   String
  sequenceConfig Json // 序列配置 JSON
  candidateIds   String[] // 目标候选人 IDs

  // 状态
  status      String @default("draft") // draft, active, paused, completed, cancelled, failed
  currentStep Int    @default(1) // 当前步骤
  totalSteps  Int // 总步骤数

  // 统计
  sentCount    Int @default(0)
  failedCount  Int @default(0)
  repliedCount Int @default(0)

  // 时间调度
  nextSendAt     DateTime?
  scheduledAt    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  lastActivityAt DateTime?

  // 元数据
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([status, nextSendAt])
  @@map("sequence_instances")
}

// ==================== 获客雷达错误日志 ====================

model RadarError {
  id       String @id @default(cuid())
  tenantId String

  // 错误来源
  adapter   String // ted, ungm, brave, hunter, etc.
  operation String // search, enrich, validate, etc.
  error     String // 错误信息

  // 关联数据
  candidateId String?
  query       String?

  // 时间戳
  timestamp DateTime @default(now())

  @@index([adapter, timestamp])
  @@index([tenantId, timestamp])
  @@map("radar_errors")
}

// ==================== 获客雷达 → 营销内容联动 ====================

enum ContentLinkType {
  KEYWORD_MATCH // 关键词匹配
  INDUSTRY_MATCH // 行业匹配
  OUTREACH_EMBED // 外联嵌入
  MANUAL // 手动关联
}

model RadarContentLink {
  id       String @id @default(cuid())
  tenantId String

  // 双向关联
  candidateId String
  candidate   RadarCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  contentId   String
  content     SeoContent     @relation(fields: [contentId], references: [id], onDelete: Cascade)

  // 关联类型与细节
  linkType     ContentLinkType
  matchScore   Float? // 匹配度 0-100
  matchDetails Json? // { matchedKeywords[], reasons[], matchMethod }

  // 外联状态追踪
  outreachStatus   String? // pending | sent | opened | replied
  outreachRecordId String? // 关联 OutreachRecord id

  // 效果追踪
  clickCount     Int     @default(0)
  leadGenerated  Boolean @default(false)
  conversionNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([candidateId, contentId])
  @@index([tenantId])
  @@index([contentId])
  @@index([candidateId])
  @@map("radar_content_links")
}

// ==================== GEO 分发追踪 ====================

enum GeoChannel {
  CHATGPT // ChatGPT / ChatGPT Search
  PERPLEXITY // Perplexity AI
  CLAUDE // Claude
  GEMINI // Gemini / Google AI Overviews
  BING_COPILOT // Bing Copilot
  CUSTOM_SITE // 客户独立站
}

enum CitationStatus {
  PENDING // 待检测
  CITED // 已被引用
  NOT_CITED // 未被引用
  PARTIAL // 部分引用
  ERROR // 检测失败
}

model GeoDistributionRecord {
  id       String @id @default(cuid())
  tenantId String

  // 关联内容
  contentId String
  content   SeoContent @relation(fields: [contentId], references: [id], onDelete: Cascade)

  // 分发渠道
  channel       GeoChannel
  channelDetail String? // e.g. "ChatGPT Search", "Google AI Overviews"

  // 分发内容快照
  distributedVersion String? // 分发时的 geoVersion 快照（前200字）
  queryKeywords      String[] // 用于检测引用的查询词

  // 引用追踪
  citationStatus  CitationStatus @default(PENDING)
  citationUrl     String? // AI 引擎引用的 URL
  citationSnippet String? // AI 引擎引用的片段
  citationScore   Float? // 引用质量评分 0-100
  lastCheckedAt   DateTime?

  // 检测历史
  checkCount   Int   @default(0)
  checkHistory Json? // [{ checkedAt, status, snippet }]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contentId, channel])
  @@index([tenantId])
  @@index([citationStatus])
  @@map("geo_distribution_records")
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type      String // "tier_a_lead" | "geo_citation" | "publish_failed" | "system"
  title     String
  body      String
  actionUrl String?
  readAt    DateTime?

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, readAt])
  @@map("notifications")
}

model RadarDailySnapshot {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  dayKey             String
  rawCandidates      Int  @default(0)
  qualifiedCompanies Int  @default(0)
  importedProspects  Int  @default(0)
  contactsAdded      Int  @default(0)
  readyCompanies     Int  @default(0)

  workspaceTotal     Int  @default(0)
  readyNowCount      Int  @default(0)
  phonePriorityCount Int  @default(0)
  emailPriorityCount Int  @default(0)
  pendingCount       Int  @default(0)
  avgReadyScore      Int  @default(0)

  feedbackSummary Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, dayKey])
  @@index([tenantId, dayKey])
  @@map("radar_daily_snapshots")
}

// ==================== WEB CRAWL QUEUE ====================

model CrawlQueue {
  id       String  @id @default(cuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String // 发起用户 ID
  batchId  String  @unique // 用于前端轮询
  rootUrl  String // 根 URL
  folderId String? // 可选的文件夹 ID

  // 进度跟踪
  totalPages     Int
  processedPages Int    @default(0)
  status         String @default("pending") // pending | processing | completed | failed

  // URL 队列 (JSON 数组)
  urls Json // [{ url, status, priority, assetId?, error?, processedAt? }]

  // 元数据
  metadata Json? // { discoveryMethod, requestedAt, maxPagesRequested, lastProcessedAt, lastStats, completedAt, lastError }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([batchId])
  @@index([tenantId, status])
  @@map("crawl_queue")
}

// ==================== ASSET PROCESSING QUEUE ====================
// 后台处理大文件文本提取和分块

model AssetProcessQueue {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String // 发起用户 ID
  batchId  String @unique // 用于前端轮询

  // 关联资产
  assetId    String
  storageKey String
  mimeType   String

  // 进度跟踪
  status      String  @default("pending") // pending | extracting | chunking | completed | failed
  progress    Int     @default(0) // 0-100 百分比
  currentStep String? // "extracting_text" | "splitting_chunks" | "creating_records"

  // 错误信息
  errorMessage String?

  // 元数据
  metadata Json? // { fileName, fileSize, chunkCount?, textLength?, startedAt?, completedAt? }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([batchId])
  @@index([assetId])
  @@index([tenantId, status])
  @@map("asset_process_queue")
}

// 商务咨询留言（来自登录页"获取使用资格"入口）
model Inquiry {
  id        String   @id @default(cuid())
  name      String
  company   String
  email     String
  phone     String?
  message   String?
  status    String   @default("new") // new | read | handled
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("inquiries")
}
