// ==================== е§қпҪ…зҙЎйҸҲиҪ°зҙ°й”ӣе ҹе«‘йҸҚеӣӘжөҶйҚ–ж §жӮ—й”ӣ?====================

model Opportunity {
  id       String @id @default(cuid())
  tenantId String

  // йҚҸе® д»ҲйҚҸо„Җеҫғ
  companyId String?
  company   ProspectCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  // йҸүгғҰз°®
  sourceType        String // tender | project | referral | inbound
  sourceCandidateId String?
  sourceUrl         String?

  // йҸҚзЁҝзёҫж·Үв„ғдј…
  title       String
  description String?

  // йҸғе •жЈҝж¶“еәЁеҷҫжЈ°?
  deadline       DateTime?
  estimatedValue Float?
  currency       String?

  // йҚ’е—ҷиў«
  categoryCode String?
  categoryName String?

  // й—ғиҲөоҶҢз» пј„жӮҠ
  stage       OpportunityStage @default(IDENTIFIED)
  probability Int? // 0-100
