}

// ==================== 鏁版嵁婧愮洰褰?====================

model RadarSource {
  id       String  @id @default(cuid())
  tenantId String? // null = 绯荤粺绾у叕鍏辨簮

  // 鍒嗙被
  channelType ChannelType

  // 鍩虹淇℃伅
  name        String
  code        String  @unique
  description String?
  logoUrl     String?
  websiteUrl  String?

  // 瑕嗙洊鑼冨洿
  countries String[] // ISO codes, 绌?= 鍏ㄧ悆
  regions   String[] // EU | LATAM | MENA | APAC 绛?

  // 鎺ュ叆閰嶇疆
  adapterType   AdapterType
  adapterConfig Json        @default("{}") // API endpoint, auth, field mapping 绛?

  // 鍚堣涓庣瓥鐣?
  isOfficial          Boolean            @default(false) // 鏄惁瀹樻柟婧?
  requiresAuth        Boolean            @default(false)
  termsUrl            String?
  storagePolicy       RadarStoragePolicy @default(TTL_CACHE)
  ttlDays             Int                @default(90)
  attributionRequired Boolean            @default(true)

  // 閫熺巼闄愬埗
  rateLimit Json @default("{}") // { requests, windowMs }

  // 鐘舵€?
  isEnabled  Boolean   @default(true)
  lastSyncAt DateTime?
  syncStats  Json? // { totalFetched, lastError, avgResponseTime }

  // 鍏崇郴
  candidates RadarCandidate[]
  tasks      RadarTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== 鍙戠幇浠诲姟 ====================

model RadarTask {
  id       String @id @default(cuid())
  tenantId String

  // 浠诲姟閰嶇疆
  name     String?
  sourceId String
  source   RadarSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  // 鐢诲儚寮曠敤锛堝彲杩芥函锛?
  targetingRef  Json? // { segmentId?, personaId?, specVersionId? }
  channelMapRef String? // 寮曠敤 ArtifactVersion id

  // 鏌ヨ璁″垝
  queryConfig Json // 鎼滅储鍙傛暟锛歬eywords, categories, regions, dateRange

  // 鎵ц鐘舵€?
  status      RadarTaskStatus @default(PENDING)
  startedAt   DateTime?
  completedAt DateTime?
  cancelToken String?

  // 缁熻
  stats        Json? // { fetched, new, duplicate, errors, duration }
  errorMessage String?

  // 瑙﹀彂鏂瑰紡
  triggeredBy  String // userId | "scheduler" | "manual"
  scheduleRule String? // cron expression for recurring

  // 鍏崇郴
  candidates RadarCandidate[]

  createdAt DateTime @default(now())
}

// ==================== 缁熶竴鍊欓€夋睜 ====================

model RadarCandidate {
  id       String @id @default(cuid())
  tenantId String

  // 鏉ユ簮杩芥函锛堝繀椤伙級
  sourceId String
