  errorCode String?
  metadata  Json? // { query, resultCount, duration }

  // 鏃堕棿鎴?
  createdAt DateTime @default(now())

  @@map("api_call_logs")
}

// ==================== 缁熶竴API瀵嗛挜绠＄悊锛圱ower鍚庡彴锛?====================

model ApiKeyConfig {
