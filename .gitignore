# ============================================================
# VertaX .gitignore — Whitelist approach for clean repo hygiene
# ============================================================

# ----- Dependencies -----
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ----- Testing -----
/coverage
/playwright-report
/test-results
tests/screenshots
tests/test-results
tests/test-results.json
tests/playwright-report

# ----- Next.js -----
/.next/
/out/

# ----- Production builds -----
/build
/dist

# ----- OS & Editor files -----
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# ----- Debug logs -----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ----- Environment files (ONLY .env.example is allowed) -----
.env
.env.*
!.env.example

# ----- Vercel -----
.vercel
.vercel-tmp/

# ----- TypeScript -----
*.tsbuildinfo
next-env.d.ts

# ----- Generated code -----
/src/generated/prisma

# ----- Python artifacts -----
__pycache__/
*.pyc
*.pyo
.venv/

# ----- AI/Editor tool directories (local-only, never commit) -----
.qoder/
.trae/
.cursor/
.accio-audit/
.bolt/
.windsurf/
.agent-browser/
.codex-tmp/
.codex/
.tmp-browser-state.json

# ----- Temp fix/patch scripts (generated by AI agents) -----
_*.py
_*.mjs
_*.ps1
_*.sh

# ----- Data files (never belong in code repo) -----
*.xlsx
*.xls
*.csv
*.docx
*.doc
*.pptx
*.ppt
*.pdf
!docs/**/*.pdf

# ----- Media/generated assets & archives -----
vibe_images/
*.rdb
*.zip
*.tar.gz
*.rar

# ----- Temp & backup directories -----
backup/
temp_clone/
workspace/
generated/
tmp/
temp/
/tmp_*

# ----- Build/debug outputs -----
tsc-out.txt
*.log

# ----- Skills lock (local tool config, root-level only) -----
/skills/
/skills-lock.json

# ----- Supabase local -----
supabase/

# ----- Doc tools -----
doc_tools/

# ----- Other projects / sub-projects (DO NOT mix repos) -----
epxfresh/
epxfresh-website
fadreamworks
hanwei-cnc
stonehub
sunmay-b2b
ViciVidi
machrio/
mroport.com/
paintcell/
paintcell-site/
ryan823-project/
vetsphere/
shipyard-xevora/
POD-Dreamworks/
-/

# ----- Misc one-off files that should never be committed -----
COMPARE_REPORT.md
REDIRECTS.md
REDIRECTS_UPDATE.md
VERTAX_USER_GUIDE.html
docs/VERTAX_CHANNEL_PARTNER_ENTERPRISE_GUIDE.html
docs/VERTAX_To企业_客户负责人说明.html
SEO-GEO-AUDIT-AND-PLAN.md
generate_agreement.py
seed-website-config.mjs
export-candidates.cjs
all_category_slugs.*
category_mapping.json
category_redirects.json
product_redirects_from_404.json
generated_product_redirects.json
test-*.js
tmp-*.js
radar-demo.html
nul

.vercel
